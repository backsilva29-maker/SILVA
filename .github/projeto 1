function salvarGrupo(gi) {
  const nome=document.getElementById('mg-nome').value.trim();
  if(!nome){mostrarNotificacao('Informe o nome!','error');return;}
  const obj={nome,inicio:parseInt(document.getElementById('mg-inicio').value)||0,duracao:parseInt(document.getElementById('mg-dur').value)||2,responsavel:document.getElementById('mg-resp').value.trim()||'Equipe',cor:document.getElementById('mg-cor').value};
  if(gi===null){dados.grupos.push({id:'g'+uid(),tarefas:[],...obj});renumerarGrupos();mostrarNotificacao('Grupo criado!','success');}
  else{Object.assign(dados.grupos[gi],obj);mostrarNotificacao('Grupo atualizado!','success');}
  agendarSync();fecharModal();renderizarGantt();
}
function alterarCorGrupo(gi) {
  const inp=document.createElement('input');inp.type='color';inp.value=dados.grupos[gi].cor;
  inp.onchange=()=>{dados.grupos[gi].cor=inp.value;agendarSync();renderizarGantt();};inp.click();
}
function abrirModalTarefa(gi, ti) {
  const novo=ti===null;
  const g=dados.grupos[gi];
  let iSug=g.inicio||0;
  if(g.tarefas.length>0){const ul=g.tarefas[g.tarefas.length-1];iSug=ul.inicio+ul.duracao;}
  const t=novo?{nome:'',inicio:iSug,duracao:2,responsavel:g.responsavel||'Equipe',progresso:0}:g.tarefas[ti];
  abrirModal(novo?'Nova Tarefa':'Editar Tarefa',`
    <div style="margin-bottom:8px;font-size:11px;color:var(--text2)">Grupo: <strong style="color:var(--accent)">${g.nome}</strong></div>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:11px;color:var(--text2);display:block;margin-bottom:4px">Nome *</label>
        <input id="mt-nome" class="crud-input" value="${t.nome}"></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
        <div><label style="font-size:11px;color:var(--text2);display:block;margin-bottom:4px">Semana Início</label>
          <input id="mt-inicio" class="crud-input" type="number" min="0" value="${t.inicio}"></div>
        <div><label style="font-size:11px;color:var(--text2);display:block;margin-bottom:4px">Duração (sem)</label>
          <input id="mt-dur" class="crud-input" type="number" min="1" value="${t.duracao}"></div>
      </div>
      <div><label style="font-size:11px;color:var(--text2);display:block;margin-bottom:4px">Responsável</label>
        <input id="mt-resp" class="crud-input" value="${t.responsavel}"></div>
      <div><label style="font-size:11px;color:var(--text2);display:block;margin-bottom:4px">
        Progresso: <strong id="mt-pct" style="color:${g.cor}">${t.progresso}%</strong></label>
        <input id="mt-prog" type="range" min="0" max="100" value="${t.progresso}" style="width:100%;accent-color:${g.cor}"
          oninput="document.getElementById('mt-pct').textContent=this.value+'%'"></div>
      <div style="display:flex;gap:8px;justify-content:flex-end">
        <button class="btn btn-ghost" onclick="fecharModal()">Cancelar</button>
        <button class="btn btn-primary" onclick="salvarTarefa(${gi},${novo?'null':ti})">${novo?'+ Adicionar':'Salvar'}</button>
      </div>
    </div>`);
}
function salvarTarefa(gi, ti) {
  const nome=document.getElementById('mt-nome').value.trim();
  if(!nome){mostrarNotificacao('Informe o nome!','error');return;}
  const obj={nome,inicio:parseInt(document.getElementById('mt-inicio').value)||0,duracao:parseInt(document.getElementById('mt-dur').value)||2,responsavel:document.getElementById('mt-resp').value.trim()||'Equipe',progresso:parseInt(document.getElementById('mt-prog').value)||0};
  if(ti===null){dados.grupos[gi].tarefas.push(obj);mostrarNotificacao('Tarefa adicionada!','success');}
  else{Object.assign(dados.grupos[gi].tarefas[ti],obj);mostrarNotificacao('Tarefa atualizada!','success');}
  if(obj.progresso===100) dispararN8N('tarefa_concluida', { grupo: dados.grupos[gi].nome, tarefa: obj.nome, responsavel: obj.responsavel });
  agendarSync();fecharModal();renderizarGantt();
}
function excluirTarefa(gi,ti){if(confirm('Excluir tarefa?')){dados.grupos[gi].tarefas.splice(ti,1);agendarSync();renderizarGantt();mostrarNotificacao('Excluída!','success');}}
function adicionarGrupo(){abrirModalGrupo(null);}
function renumerarGrupos(){dados.grupos.forEach((g,i)=>{g.nome=g.nome.replace(/^\d+\.\s*/,'');g.nome=`${i+1}. ${g.nome}`;});}
function excluirGrupo(gi){if(confirm('Excluir grupo e todas as tarefas?')){dados.grupos.splice(gi,1);renumerarGrupos();agendarSync();renderizarGantt();mostrarNotificacao('Excluído!','success');}}
function exportarCronograma(){
  const linhas=[];
  dados.grupos.forEach(g=>{
    linhas.push({Grupo:g.nome,Tarefa:'',Inicio:fmtSemana(g.inicio),Fim:fmtSemana(g.inicio+g.duracao),Duracao:g.duracao,Progresso:calcularProgressoGrupo(g)+'%'});
    g.tarefas.forEach(t=>linhas.push({Grupo:g.nome,Tarefa:t.nome,Inicio:fmtSemana(t.inicio),Fim:fmtSemana(t.inicio+t.duracao),Duracao:t.duracao,Progresso:t.progresso+'%'}));
  });
  const wb=XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb,XLSX.utils.json_to_sheet(linhas),'Cronograma');
  XLSX.writeFile(wb,'cronograma.xlsx');
  mostrarNotificacao('Exportado!','success');
}

