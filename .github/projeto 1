function iaImportarOrcamento(resultStr) {
  try {
    const result = typeof resultStr === 'string' ? JSON.parse(resultStr.replace(/&quot;/g,'"')) : resultStr;
    const orc = orcDados();
    let importados = 0;
    (result.servicos||[]).forEach(s => {
      orc.servicos.push({
        id:uid(), item:s.item||'', codigo:s.codigo||'', nome:s.nome||'',
        unidade:s.unidade||'un', quantidade:s.quantidade||0,
        precoUnit:s.precoUnit||0, totalCD:s.totalCD||0
      });
      importados++;
    });
    (result.composicoes||[]).forEach(c => {
      orc.composicoes.push({
        id:uid(), codigo:c.codigo||'', descricao:c.descricao||'',
        unidade:c.unidade||'un', quantidade:c.quantidade||0,
        etapa:c.etapa||'', precoUnit:c.precoUnit||0, fonte:'IA-Groq'
      });
    });
    agendarSync();
    mostrarNotificacao(`✅ ${importados} serviços importados para o orçamento!`,'success');
    mudarModo('orcamento');
  } catch(e) { mostrarNotificacao('Erro ao importar: '+e.message,'error'); }
}

