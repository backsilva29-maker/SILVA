let _dragSrcGi = null;
function renderizarGantt() {
  const body = document.getElementById('ganttBody');
  if(!body) return;
  body.innerHTML = '';
  const semA = getSemanaAtual();
  dados.grupos.forEach((g, gi) => {
    const pg = calcularProgressoGrupo(g);
    const div = document.createElement('div');
    div.className = 'gantt-group';
    div.setAttribute('draggable', 'true');
    div.dataset.gi = gi;
    div.style.transition = 'opacity .15s, transform .15s';
    div.addEventListener('dragstart', e => { _dragSrcGi = gi; e.dataTransfer.effectAllowed = 'move'; setTimeout(()=>div.style.opacity='0.4',0); });
    div.addEventListener('dragend', () => { div.style.opacity='1'; document.querySelectorAll('.gantt-group').forEach(el=>el.style.borderTop=''); });
    div.addEventListener('dragover', e => { e.preventDefault(); e.dataTransfer.dropEffect='move'; document.querySelectorAll('.gantt-group').forEach(el=>el.style.borderTop=''); if(_dragSrcGi!==gi) div.style.borderTop='2px solid var(--accent)'; });
    div.addEventListener('dragleave', ()=>{ div.style.borderTop=''; });
    div.addEventListener('drop', e => {
      e.preventDefault(); div.style.borderTop='';
      if(_dragSrcGi===null||_dragSrcGi===gi) return;
      const moved = dados.grupos.splice(_dragSrcGi,1)[0];
      const newTarget = _dragSrcGi<gi?gi-1:gi;
      dados.grupos.splice(newTarget,0,moved);
      renumerarGrupos(); agendarSync(); renderizarGantt();
      mostrarNotificacao('Grupos reordenados! ✓','success'); _dragSrcGi=null;
    });
    const hdr = document.createElement('div');
    hdr.className = 'gantt-group-header';
    hdr.innerHTML = `
      <div class="gc" style="gap:6px">
        <span style="cursor:grab;color:var(--text3);font-size:14px;user-select:none">⠿</span>
        <div class="dot" style="background:${g.cor};cursor:pointer" onclick="alterarCorGrupo(${gi})" title="Alterar cor"></div>
        <input class="gc-edit" value="${g.nome}" onchange="dados.grupos[${gi}].nome=this.value;agendarSync();">
      </div>
      <div class="gc" style="font-size:11px;color:var(--text2)">${fmtSemana(g.inicio)}</div>
      <div class="gc" style="font-size:11px;color:var(--text2)">${fmtSemana(g.inicio+g.duracao)}</div>
      <div class="gc"><input class="gc-edit" type="number" min="1" value="${g.duracao}" onchange="dados.grupos[${gi}].duracao=parseInt(this.value)||1;agendarSync();renderizarGantt();"></div>
      <div class="gc"><span style="color:var(--accent);font-weight:600">${pg}%</span></div>
      <div class="gc" style="padding:0;overflow:hidden"><div class="bar-area">
        <div class="today-line" style="left:${semA*SEMANA_PX}px"></div>
        <div class="gantt-bar" style="left:${g.inicio*SEMANA_PX}px;width:${g.duracao*SEMANA_PX}px;background:${g.cor}33;border:1px solid ${g.cor}">
          <div class="gantt-bar-fill" style="width:${pg}%;background:${g.cor}"></div>
        </div>
      </div></div>`;
    div.appendChild(hdr);
    g.tarefas.forEach((t, ti) => {
      const row = document.createElement('div');
      row.className = 'gantt-row';
      row.innerHTML = `
        <div class="gc" style="padding-left:44px;gap:4px">
          <input class="gc-edit" value="${t.nome}" onchange="dados.grupos[${gi}].tarefas[${ti}].nome=this.value;agendarSync();">
          <button class="btn-crud btn-crud-edit" onclick="abrirModalTarefa(${gi},${ti})">Edit</button>
          <button class="btn-crud btn-crud-del" onclick="excluirTarefa(${gi},${ti})">Del</button>
        </div>
        <div class="gc" style="font-size:11px;color:var(--text2)">${fmtSemana(t.inicio)}</div>
        <div class="gc" style="font-size:11px;color:var(--text2)">${fmtSemana(t.inicio+t.duracao)}</div>
        <div class="gc"><input class="gc-edit" type="number" min="1" value="${t.duracao}" onchange="dados.grupos[${gi}].tarefas[${ti}].duracao=parseInt(this.value)||1;agendarSync();renderizarGantt();"></div>
        <div class="gc" style="gap:6px">
          <input type="range" min="0" max="100" value="${t.progresso}" style="width:70px;accent-color:${g.cor}"
            oninput="dados.grupos[${gi}].tarefas[${ti}].progresso=parseInt(this.value);agendarSync();this.nextElementSibling.textContent=this.value+'%';">
          <span style="min-width:32px;font-size:11px">${t.progresso}%</span>
        </div>
        <div class="gc" style="padding:0;overflow:hidden"><div class="bar-area">
          <div class="today-line" style="left:${semA*SEMANA_PX}px"></div>
          <div class="gantt-bar" style="left:${t.inicio*SEMANA_PX}px;width:${t.duracao*SEMANA_PX}px;background:${g.cor}22;border:1px solid ${g.cor}55">
            <div class="gantt-bar-fill" style="width:${t.progresso}%;background:${g.cor}"></div>
          </div>
        </div></div>`;
      div.appendChild(row);
    });
    const act = document.createElement('div');
    act.className = 'gantt-row';
    act.innerHTML = `<div class="gc" style="padding-left:12px;gap:6px;flex-wrap:wrap">
      <button class="btn btn-primary" style="font-size:11px;padding:5px 10px" onclick="abrirModalTarefa(${gi},null)">+ Tarefa</button>
      <button class="btn btn-ghost" style="font-size:11px;padding:5px 10px" onclick="abrirModalGrupo(${gi})">Editar Grupo</button>
      <button class="btn btn-danger" style="font-size:11px;padding:5px 10px" onclick="excluirGrupo(${gi})">Excluir Grupo</button>
    </div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div>`;
    div.appendChild(act);
    body.appendChild(div);
  });
}
function abrirModalGrupo(gi) {
  const novo=gi===null;
