// Função auxiliar para carregar scripts sob demanda
function carregarScript(src) {
  return new Promise((resolve, reject) => {
    if (document.querySelector(`script[src="${src}"]`)) {
      resolve();
      return;
    }
    const script = document.createElement('script');
    script.src = src;
    script.onload = resolve;
    script.onerror = reject;
    document.head.appendChild(script);
  });
}

// Função para processar a planilha de preços com detecção inteligente e mapeamento manual
async function processarTabelaPrecos(file) {
  if (!file) return;
  mostrarNotificacao('Lendo planilha...', 'syncing');
  try {
    // Carregar XLSX dinamicamente se necessário
    if (typeof XLSX === 'undefined') {
      await carregarScript('https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js');
    }

    const reader = new FileReader();
    reader.onload = e => {
      try {
        const data = e.target.result;
        const wb = XLSX.read(data, { type: 'binary' });
        // Se houver múltiplas abas, perguntar qual usar? Por simplicidade, pegamos a primeira
        const sheetName = wb.SheetNames[0];
        const ws = wb.Sheets[sheetName];
        const rows = XLSX.utils.sheet_to_json(ws, { header: 1, defval: '' });

        // Encontrar linha de cabeçalho
        const cabecalho = encontrarCabecalho(rows);
        if (!cabecalho) {
          mostrarNotificacao('Não foi possível identificar o cabeçalho da planilha.', 'error');
          return;
        }

        const { headerRow, headerIndex } = cabecalho;
        const colunas = detectarColunas(headerRow);

        // Se a detecção encontrou pelo menos código e descrição, prosseguir, senão abrir mapeamento manual
        if (colunas.codigo >= 0 && colunas.descricao >= 0 && colunas.preco >= 0) {
          // Detecção confiável, importar diretamente
          importarTabela(rows, headerIndex, colunas);
        } else {
          // Guardar rows temporariamente para usar no mapeamento
          window._tempRows = rows;
          window._tempHeaderIndex = headerIndex;
          abrirMapeamentoColunas(headerRow, sheetName);
        }
      } catch (err) {
        mostrarNotificacao('Erro ao ler: ' + err.message, 'error');
      }
    };
    reader.readAsBinaryString(file);
  } catch (err) {
    mostrarNotificacao('Erro ao carregar biblioteca: ' + err.message, 'error');
  }
}

function encontrarCabecalho(rows) {
  const palavrasChave = ['cód', 'descri', 'unid', 'preç', 'valor', 'unit'];
  for (let i = 0; i < Math.min(20, rows.length); i++) {
    const row = rows[i];
    const texto = row.join(' ').toLowerCase();
    if (palavrasChave.some(p => texto.includes(p))) {
      return { headerRow: row, headerIndex: i };
    }
  }
  if (rows.length > 0) {
    return { headerRow: rows[0], headerIndex: 0 };
  }
  return null;
}

function detectarColunas(headerRow) {
  const keywords = {
    codigo: ['cód', 'cod', 'código', 'codigo', 'ref', 'item', 'nro'],
    descricao: ['descri', 'serviç', 'denomin', 'composiç'],
    unidade: ['und', 'unid', 'un', 'unidade'],
    preco: ['preç', 'preco', 'valor', 'custo', 'unit']
  };
  let colunas = { codigo: -1, descricao: -1, unidade: -1, preco: -1 };
  headerRow.forEach((cell, index) => {
    const cellStr = (cell || '').toString().toLowerCase().trim();
    for (let [tipo, palavras] of Object.entries(keywords)) {
      if (palavras.some(p => cellStr.includes(p))) {
        colunas[tipo] = index;
      }
    }
  });
  return colunas;
}

function importarTabela(rows, headerIndex, colunas) {
  const orc = orcDados();
  const importados = [];
  for (let i = headerIndex + 1; i < rows.length; i++) {
    const r = rows[i];
    if (!r || r.length === 0) continue;
    const codigo = (r[colunas.codigo] || '').toString().trim();
    const descricao = (r[colunas.descricao] || '').toString().trim();
    if (!codigo && !descricao) continue;
    let precoStr = (r[colunas.preco] || '').toString()
      .replace(/R\$\s*/g, '').replace(/\./g, '').replace(',', '.').trim();
    const preco = parseFloat(precoStr) || 0;
    let unidade = colunas.unidade >= 0 ? (r[colunas.unidade] || '').toString().trim() : 'un';
    importados.push({ codigo, descricao, unidade, preco });
  }
  if (importados.length === 0) {
    mostrarNotificacao('Nenhum item encontrado.', 'error');
    return;
  }
  orc.tabelaImportada = importados;
  agendarSync();
  mudarSubOrc('tabPrecos');
  mostrarNotificacao(`✅ ${importados.length} itens importados!`, 'success');
  delete window._tempRows;
}

function abrirMapeamentoColunas(headerRow, sheetName) {
  const opcoes = headerRow.map((cell, idx) => `<option value="${idx}">${cell || `Coluna ${idx+1}`}</option>`).join('');
  const modalHtml = `
    <h3>Mapear Colunas</h3>
    <p>Aba: ${sheetName}</p>
    <div style="display:grid;gap:10px">
      <label>Código: <select id="mapCodigo">${opcoes}</select></label>
      <label>Descrição: <select id="mapDescricao">${opcoes}</select></label>
      <label>Unidade: <select id="mapUnidade">${opcoes}</select></label>
      <label>Preço: <select id="mapPreco">${opcoes}</select></label>
    </div>
    <button class="btn btn-primary" onclick="confirmarMapeamento()">Confirmar</button>
  `;
  abrirModal('Mapear Colunas da Tabela', modalHtml);
  // Pré-selecionar as detectadas (se houver)
  const colunasDetectadas = window._colunasDetectadas || {};
  setTimeout(() => {
    if (colunasDetectadas.codigo >= 0) document.getElementById('mapCodigo').value = colunasDetectadas.codigo;
    if (colunasDetectadas.descricao >= 0) document.getElementById('mapDescricao').value = colunasDetectadas.descricao;
    if (colunasDetectadas.unidade >= 0) document.getElementById('mapUnidade').value = colunasDetectadas.unidade;
    if (colunasDetectadas.preco >= 0) document.getElementById('mapPreco').value = colunasDetectadas.preco;
  }, 100);
}

window.confirmarMapeamento = function() {
  const colunas = {
    codigo: parseInt(document.getElementById('mapCodigo').value),
    descricao: parseInt(document.getElementById('mapDescricao').value),
    unidade: parseInt(document.getElementById('mapUnidade').value),
    preco: parseInt(document.getElementById('mapPreco').value)
  };
  if (!window._tempRows) {
    mostrarNotificacao('Erro: dados da planilha perdidos.', 'error');
    return;
  }
  importarTabela(window._tempRows, window._tempHeaderIndex, colunas);
  fecharModal();
};

