      ${renderizarItensVersao(itens.slice(0,40), id, mesRef)}
    </div>
    <div style="font-size:11px;color:var(--text3);margin-top:8px;display:flex;justify-content:space-between">
      <span>${itens.length} itens · ${id} · ${mesRef}</span>
      <button class="btn btn-primary" style="font-size:10px;padding:3px 10px"
