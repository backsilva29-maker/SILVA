// ── CANÔNICA — única definição válida de chave/dedup/soma ──────────
function iaChaveSim(item) {
  const d=(item.descricao||item.nome||'').toLowerCase();
  const stop=new Set(['de','do','da','em','para','com','na','no','ao','a','o','e','um','uma','por']);
  const p=d.replace(/[^\w\s]/g,'').split(/\s+/).filter(w=>w.length>2&&!stop.has(w)).slice(0,4).sort().join('|');
  return `${(item.etapa||item.ambiente||'').toLowerCase()}|${(item.unidade||'').toLowerCase()}|${p}`;
}
// Alias — mantém compatibilidade com chamadas iaChaveSimilaridade()
const iaChaveSimilaridade = iaChaveSim;

// ...campos aceito por assinatura para compatibilidade — dedup é sempre por iaChaveSim
function iaDeduplicar(arr, ...campos) {
  const v=new Map();
  return arr.filter(it=>{ const k=iaChaveSim(it); if(v.has(k))return false; v.set(k,true); return true; });
}

function iaSomarDuplicatas(arr) {
  const map=new Map();
  arr.forEach(it=>{
    const k=iaChaveSim(it);
    if(map.has(k)){
      const ex=map.get(k);
      if((it.descricao||it.nome||'').length>(ex.descricao||ex.nome||'').length){ex.descricao=it.descricao||ex.descricao;ex.nome=it.nome||ex.nome;ex.codigo=it.codigo||ex.codigo;}
      if((it.unidade||'')===(ex.unidade||'')){ex.quantidade=(parseFloat(ex.quantidade)||0)+(parseFloat(it.quantidade)||0);ex.totalCD=(parseFloat(ex.totalCD)||0)+(parseFloat(it.totalCD)||0);}
    } else { map.set(k,{...it}); }
  });
  return Array.from(map.values());
}
