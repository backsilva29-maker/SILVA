  const html = `
    <div style="background:var(--surface);border:1px solid rgba(14,201,138,.3);border-radius:var(--r-lg);overflow:hidden;margin-top:4px">
      <div style="background:rgba(14,201,138,.07);padding:14px 18px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px">
        <div>
          <div style="font-weight:800;font-size:14px;color:var(--accent3)">✅ Orçamento gerado!</div>
          <div style="font-size:11px;color:var(--text2);margin-top:2px">${result.titulo||'—'} · ${(result.servicos||[]).length} serviços</div>
        </div>
        <div style="display:flex;gap:8px">
          <button class="btn btn-success" onclick="iaImportarOrcamento(${JSON.stringify(result).replace(/"/g,'&quot;')})">✅ Importar</button>
          <button class="btn btn-ghost" onclick="this.closest('[style]').innerHTML=''">✕</button>
        </div>
      </div>
      <div style="padding:14px 18px">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:14px">
          <div style="background:var(--surface2);border-radius:var(--r-md);padding:10px"><div style="font-size:10px;color:var(--text3);margin-bottom:3px;font-family:'JetBrains Mono',monospace">CUSTO DIRETO</div><div style="font-size:16px;font-weight:800;color:var(--accent)">${fmtR(totalCD)}</div></div>
          <div style="background:var(--surface2);border-radius:var(--r-md);padding:10px"><div style="font-size:10px;color:var(--text3);margin-bottom:3px;font-family:'JetBrains Mono',monospace">SERVIÇOS</div><div style="font-size:16px;font-weight:800">${(result.servicos||[]).length}</div></div>
        </div>
        ${result.observacoes?`<div style="background:rgba(240,165,0,.06);border:1px solid rgba(240,165,0,.2);border-radius:var(--r-md);padding:10px;font-size:11px;color:var(--text2);margin-bottom:12px">${result.observacoes}</div>`:''}
        <div class="tbl-wrap">
          <div class="tbl-header" style="display:grid;grid-template-columns:40px 1fr 55px 70px 95px 100px">
            <div class="tc">#</div><div class="tc">Serviço</div><div class="tc">Und</div><div class="tc">Qtd</div><div class="tc">P.Unit</div><div class="tc" style="border-right:none">Total CD</div>
          </div>
          ${(result.servicos||[]).map((s,i)=>`
          <div class="tbl-row" style="display:grid;grid-template-columns:40px 1fr 55px 70px 95px 100px">
            <div class="tc" style="color:var(--text3);font-size:11px">${s.item||i+1}</div>
            <div class="tc" style="font-size:11px">${s.nome||''}</div>
            <div class="tc" style="font-size:10px;color:var(--text3)">${s.unidade||''}</div>
            <div class="tc" style="font-size:11px">${(s.quantidade||0).toLocaleString('pt-BR',{maximumFractionDigits:2})}</div>
            <div class="tc" style="font-size:11px;font-family:'JetBrains Mono',monospace">${fmtR(s.precoUnit||0)}</div>
            <div class="tc" style="font-size:11px;font-weight:700;color:var(--accent3);font-family:'JetBrains Mono',monospace;border-right:none">${fmtR(s.totalCD||0)}</div>
          </div>`).join('')}
        </div>
      </div>
    </div>`;
  if(container) container.innerHTML = html;
  // também atualiza o output principal
  const out = document.getElementById('iaOrcOutput');
  if(out) out.innerHTML = html;
}

async function iaGerarOrcamento(modo='completo') {
  const key = (document.getElementById('iaOrcGroqKey')?.value || getGroqKey()).trim();
  const modelo = document.getElementById('iaOrcModelSel')?.value || groqModel;
  const prompt = (document.getElementById('iaOrcPrompt')?.value||'').trim();
  const out = document.getElementById('iaOrcOutput');
  groqModel = modelo;
  if(!key) { mostrarNotificacao('Configure a chave API Groq acima.','error'); return; }
  if(!prompt) { mostrarNotificacao('Descreva a obra no campo acima.','error'); return; }
  if(out) out.innerHTML=`
    <div style="display:flex;align-items:center;gap:12px;background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:18px">
      <div style="width:20px;height:20px;border:2px solid var(--accent5);border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite;flex-shrink:0"></div>
      <div>
        <div style="font-weight:600;color:var(--accent5)">✦ IA analisando e gerando orçamento...</div>
        <div style="font-size:11px;color:var(--text3);margin-top:2px">Modelo: ${modelo} · Isso pode levar 10–30 segundos</div>
      </div>
    </div>`;

  const orc = orcDados();
  const tabela = orc.refTabela||'SINAPI-PA';
  const modoTxt = modo==='sintetico'?'planilha sintética (grupos de serviços)':modo==='composicoes'?'composições analíticas (itens e insumos)':'levantamento completo com planilha sintética E composições analíticas';

  const sysPrompt = `Você é um orçamentista especialista em construção civil brasileiro, padrão ${tabela}.
Ao receber a descrição de uma obra, gere um ${modoTxt} profissional com quantidades calculadas.
REGRAS DE QUANTIFICAÇÃO — OBRIGATÓRIAS:
- Use as dimensões e áreas informadas na descrição para calcular todas as quantidades
- Pisos/revestimentos: área informada + 10% de perda
- Pintura de paredes: perímetro × pé-direito (use 2,70m se não informado), 2 demãos, rendimento 10m²/L
- Forro/gesso: área do ambiente
- Argamassa de assentamento: ~8 kg/m²
- Rejunte: ~0,3 kg/m²
- Impermeabilização: área + 20% sobreposição
- NUNCA retorne quantidade 0 — sempre calcule ou estime com base nos dados fornecidos
- Agrupe por etapa: Demolição, Alvenaria, Revestimentos, Pisos, Forro/Gesso, Pintura, Elétrica, Hidráulica, Marcenaria, Outros
- Inclua código SINAPI quando souber
Retorne SOMENTE JSON válido, sem texto extra, no formato:
{
  "titulo": "Título do orçamento",
  "resumo": "Breve descrição",
  "servicos": [
    {"item": "1", "codigo": "código SINAPI", "nome": "Nome do serviço", "unidade": "m²", "quantidade": 0.00, "precoUnit": 0.00, "totalCD": 0.00, "etapa": "Etapa"}
  ],
  "composicoes": [],
  "totalCD": 0.0,
  "observacoes": "Premissas e memória de cálculo das quantidades"
}`;

  try {
    const r = await fetch(GROQ_URL, {
      method:'POST',
      headers:{'Content-Type':'application/json','Authorization':'Bearer '+key},
      body: JSON.stringify({
        model: modelo,
        messages:[
          {role:'system', content:sysPrompt},
          {role:'user', content:'Gere o orçamento para:\n'+prompt+'\n\nEstado: '+(getSinapiEstado()||'PA')+'\nReferência: '+tabela}
