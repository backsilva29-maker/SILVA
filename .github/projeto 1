<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>🏗️ Torre L'iris — Gestão Inteligente</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<!-- Bibliotecas carregadas sob demanda (lazy) para reduzir peso inicial -->
<style>
/* ═══ TORRE L'IRIS v5 — REDESIGN COMPLETO ═══ */
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap');

:root {
  /* Cores base — dark premium */
  --bg:       #08090d;
  --surface:  #0f1117;
  --surface2: #161920;
  --surface3: #1c2030;
  --border:   rgba(255,255,255,.07);
  --border2:  rgba(255,255,255,.12);

  /* Accentos */
  --accent:   #f0a500;
  --accent-h: #f7b830;
  --accent2:  #4f8ef7;
  --accent3:  #0ec98a;
  --accent4:  #f04f6a;
  --accent5:  #a78bfa;

  /* Texto */
  --text:  #e8eaf4;
  --text2: #7a8299;
  --text3: #3e4459;

  /* Gantt */
  --gantt-h: 42px;

  /* Shadows */
  --shadow-sm: 0 1px 3px rgba(0,0,0,.4);
  --shadow-md: 0 4px 16px rgba(0,0,0,.5);
  --shadow-lg: 0 8px 32px rgba(0,0,0,.6);

  /* Radius */
  --r-sm: 6px;
  --r-md: 10px;
  --r-lg: 16px;
  --r-xl: 22px;
}

*{box-sizing:border-box;margin:0;padding:0;}
body{
  background:var(--bg);
  color:var(--text);
  font-family:'Plus Jakarta Sans',sans-serif;
  font-size:13px;
  min-height:100vh;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:5px;height:5px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:10px;}
::-webkit-scrollbar-thumb:hover{background:var(--text3);}

/* ── LOGIN ── */
.modal{
  display:none;position:fixed;inset:0;
  background:rgba(0,0,0,.75);backdrop-filter:blur(8px);
  z-index:900;justify-content:center;align-items:flex-start;padding:40px 16px;overflow-y:auto;
}
.modal.open{display:flex;}
.modal-content{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);
  width:100%;max-width:720px;box-shadow:0 24px 64px rgba(0,0,0,.5);
}
.modal-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:16px 20px;border-bottom:1px solid var(--border);
}
.modal-title{font-weight:700;font-size:15px;}
.modal-close{
  background:none;border:none;color:var(--text2);cursor:pointer;
  font-size:20px;line-height:1;padding:0 4px;
}
.modal-close:hover{color:var(--text);}
#modalConteudo{padding:20px;}
.login-modal{
  position:fixed;inset:0;
  background:radial-gradient(ellipse at 30% 60%, rgba(79,142,247,.08) 0%, transparent 60%),
             radial-gradient(ellipse at 80% 20%, rgba(240,165,0,.06) 0%, transparent 50%),
             rgba(0,0,0,.92);
  backdrop-filter:blur(20px);
  display:flex;justify-content:center;align-items:center;z-index:1000;
}
.login-content{
  background:var(--surface);
  border:1px solid var(--border2);
  border-radius:var(--r-xl);
  padding:44px 40px;
  width:92%;max-width:400px;
  text-align:center;
  box-shadow:var(--shadow-lg), 0 0 0 1px rgba(255,255,255,.03);
  animation:fadeSlideDown .35s ease;
}
.login-logo-wrap{
  width:64px;height:64px;
  background:linear-gradient(135deg,var(--accent) 0%,#f7b830 100%);
  border-radius:18px;
  margin:0 auto 20px;
  display:flex;align-items:center;justify-content:center;
  font-size:28px;
  box-shadow:0 8px 24px rgba(240,165,0,.35);
}
.login-title{font-size:24px;font-weight:800;letter-spacing:-.5px;margin-bottom:4px;}
.login-sub{color:var(--text3);font-size:12px;margin-bottom:28px;font-weight:400;}
.login-input{
  width:100%;padding:14px 18px;margin:6px 0;
  background:var(--surface2);
  border:1px solid var(--border2);
  border-radius:50px;
  color:var(--text);font-size:14px;outline:none;
  transition:border-color .2s, box-shadow .2s;
  font-family:'Plus Jakarta Sans',sans-serif;
}
.login-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(240,165,0,.15);}
.login-btn{
  width:100%;padding:14px;margin:6px 0;
  border:none;border-radius:50px;
  font-size:14px;font-weight:700;cursor:pointer;
  transition:all .2s;
  font-family:'Plus Jakarta Sans',sans-serif;
  letter-spacing:.01em;
}
.login-btn:hover{transform:translateY(-2px);filter:brightness(1.08);}
.login-btn:active{transform:translateY(0);}
.btn-admin{background:linear-gradient(135deg,var(--accent),var(--accent-h));color:#000;}
.btn-client{background:var(--surface3);color:var(--text2);border:1px solid var(--border2);}
.btn-client:hover{color:var(--text);}
.login-sep{display:flex;align-items:center;gap:10px;color:var(--text3);font-size:11px;margin:4px 0;}
.login-sep::before,.login-sep::after{content:'';flex:1;height:1px;background:var(--border);}

/* ── TOPBAR ── */
.topbar{
  display:flex;align-items:center;justify-content:space-between;
  padding:0 20px;height:54px;
  background:rgba(15,17,23,.85);
  backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
  position:sticky;top:0;z-index:100;
}
.logo{
  font-family:'Plus Jakarta Sans',sans-serif;
  font-weight:800;font-size:15px;
  display:flex;align-items:center;gap:10px;
  letter-spacing:-.3px;
}
.logo-badge{
  width:30px;height:30px;
  background:linear-gradient(135deg,var(--accent),var(--accent-h));
  border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-size:12px;color:#000;font-weight:800;
  box-shadow:0 2px 8px rgba(240,165,0,.3);
}
.topbar-project-badge{
  background:var(--surface2);
  border:1px solid var(--border2);
  border-radius:50px;
  padding:4px 12px;
  font-size:11px;color:var(--text2);
  display:flex;align-items:center;gap:6px;
  max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
}
.topbar-project-badge .dot{width:6px;height:6px;border-radius:50%;background:var(--accent3);flex-shrink:0;}

/* ── BUTTONS ── */
.btn{
  padding:7px 14px;border-radius:var(--r-md);border:none;cursor:pointer;
  font-family:'Plus Jakarta Sans',sans-serif;
  font-size:12px;font-weight:600;
  transition:all .15s;
  display:inline-flex;align-items:center;gap:6px;
  letter-spacing:.01em;
}
.btn-ghost{
  background:transparent;
  border:1px solid var(--border2);
  color:var(--text2);
}
.btn-ghost:hover{border-color:rgba(255,255,255,.25);color:var(--text);background:var(--surface2);}
.btn-primary{
  background:linear-gradient(135deg,var(--accent),var(--accent-h));
  color:#000;font-weight:700;
  box-shadow:0 2px 8px rgba(240,165,0,.25);
}
.btn-primary:hover{filter:brightness(1.08);box-shadow:0 4px 16px rgba(240,165,0,.35);}
.btn-danger{background:rgba(240,79,106,.15);color:var(--accent4);border:1px solid rgba(240,79,106,.3);}
.btn-danger:hover{background:var(--accent4);color:#fff;}
.btn-success{background:rgba(14,201,138,.15);color:var(--accent3);border:1px solid rgba(14,201,138,.3);}
.btn-success:hover{background:var(--accent3);color:#000;}
.btn-info{background:rgba(79,142,247,.15);color:var(--accent2);border:1px solid rgba(79,142,247,.3);}
.btn-info:hover{background:var(--accent2);color:#fff;}
.btn-purple{background:rgba(167,139,250,.15);color:var(--accent5);border:1px solid rgba(167,139,250,.3);}
.btn-purple:hover{background:var(--accent5);color:#fff;}

/* ── LAYOUT ── */
.layout{display:flex;height:calc(100vh - 54px);}

/* ── SIDEBAR ── */
.sidebar{
  width:220px;min-width:220px;
  background:var(--surface);
  border-right:1px solid var(--border);
  padding:12px 0 20px;
  overflow-y:auto;
  display:flex;flex-direction:column;
}
.sidebar-logo-area{
  padding:12px 16px 16px;
  border-bottom:1px solid var(--border);
  margin-bottom:8px;
}
.sidebar-section{margin-bottom:4px;}
.sidebar-label{
  font-family:'JetBrains Mono',monospace;
  font-size:9px;letter-spacing:1.8px;
  color:var(--text3);text-transform:uppercase;
  padding:10px 16px 4px;
  font-weight:500;
}
.sidebar-item{
  display:flex;align-items:center;gap:9px;
  padding:9px 14px 9px 16px;
  color:var(--text2);cursor:pointer;
  border-left:2px solid transparent;
  border-radius:0;
  transition:all .18s;
  font-size:12.5px;font-weight:500;
  margin:1px 0;
}
.sidebar-item:hover{
  background:var(--surface2);
  color:var(--text);
  border-left-color:var(--border2);
}
.sidebar-item.active{
  color:var(--accent);
  border-left-color:var(--accent);
  background:rgba(240,165,0,.06);
  font-weight:600;
}
.sidebar-item .icon{
  width:18px;height:18px;
  display:flex;align-items:center;justify-content:center;
  font-size:13px;flex-shrink:0;
  opacity:.85;
}
.sidebar-sub{
  font-size:11.5px;
  padding:7px 14px 7px 44px;
  color:var(--text3);cursor:pointer;
  transition:all .15s;
  border-left:2px solid transparent;
  font-weight:400;
}
.sidebar-sub:hover{color:var(--text2);background:var(--surface2);}
.sidebar-sub.active{color:var(--accent2);font-weight:600;border-left-color:var(--accent2);}

/* Sidebar project chip */
.sidebar-project-chip{
  margin:0 12px 8px;
  background:var(--surface3);
  border:1px solid var(--border2);
  border-radius:var(--r-md);
  padding:10px 12px;
  font-size:11px;
}
.sidebar-project-chip .proj-name{
  font-weight:700;color:var(--text);
  font-size:12px;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
  margin-bottom:2px;
}
.sidebar-project-chip .proj-meta{color:var(--text3);font-size:10px;}

/* ── MAIN CONTENT ── */
.main{flex:1;overflow:auto;padding:22px 26px;background:var(--bg);}
.page-header{
  display:flex;align-items:flex-start;justify-content:space-between;
  margin-bottom:22px;
  padding-bottom:18px;
  border-bottom:1px solid var(--border);
  flex-wrap:wrap;gap:12px;
}
.page-title{
  font-size:21px;font-weight:800;
  letter-spacing:-.4px;
  background:linear-gradient(90deg,var(--text) 60%,var(--text2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
}
.page-sub{color:var(--text2);font-size:12px;margin-top:5px;font-weight:400;line-height:1.5;}

/* ── STAT CARDS ── */
.stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-bottom:22px;}
.stat-card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:16px 18px;
  transition:all .2s;
  position:relative;overflow:hidden;
}
.stat-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--accent),transparent);
  opacity:0;transition:opacity .2s;
}
.stat-card:hover{border-color:var(--border2);transform:translateY(-2px);box-shadow:var(--shadow-md);}
.stat-card:hover::before{opacity:1;}
.stat-label{font-size:10px;color:var(--text3);text-transform:uppercase;font-family:'JetBrains Mono',monospace;margin-bottom:10px;letter-spacing:.8px;}
.stat-value{font-size:22px;font-weight:800;letter-spacing:-.5px;}

/* ── SYNC BAR ── */
.sync-bar{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--r-md);
  padding:10px 16px;
  margin-bottom:18px;
  display:flex;align-items:center;justify-content:space-between;
  gap:12px;flex-wrap:wrap;
}
.sync-status{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--text2);}
.sync-dot{width:7px;height:7px;border-radius:50%;background:var(--text3);flex-shrink:0;}
.sync-dot.online{background:var(--accent3);box-shadow:0 0 6px rgba(14,201,138,.5);}
.sync-dot.syncing{background:var(--accent);animation:pulse 1s infinite;box-shadow:0 0 6px rgba(240,165,0,.5);}
.sync-dot.offline{background:var(--accent4);}
.sync-dot.error{background:var(--accent4);}

/* ── ORC TABS ── */
.orc-tabs{
  display:flex;gap:3px;
  margin-bottom:20px;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:4px;flex-wrap:wrap;
}
.orc-tab{
  padding:7px 13px;border-radius:var(--r-md);
  cursor:pointer;font-size:12px;font-weight:500;
  color:var(--text2);transition:all .18s;white-space:nowrap;
}
.orc-tab:hover{color:var(--text);background:var(--surface2);}
.orc-tab.active{
  background:linear-gradient(135deg,var(--accent),var(--accent-h));
  color:#000;font-weight:700;
  box-shadow:0 2px 8px rgba(240,165,0,.3);
}

/* ── TABLES ── */
.tbl-wrap{
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  overflow:hidden;
  background:var(--surface);
}
.tbl-header{
  display:flex;
  background:var(--surface2);
  border-bottom:1px solid var(--border);
  font-family:'JetBrains Mono',monospace;
  font-size:10px;color:var(--text3);
  text-transform:uppercase;letter-spacing:.6px;
}
.tbl-row{
  display:flex;
  border-bottom:1px solid rgba(255,255,255,.04);
  align-items:stretch;transition:background .12s;
}
.tbl-row:hover{background:rgba(255,255,255,.025);}
.tbl-row.grupo{background:rgba(240,165,0,.05);font-weight:600;}
.tbl-row.subtotal{background:rgba(79,142,247,.05);font-weight:600;}
.tbl-row.total-row{background:rgba(14,201,138,.07);font-weight:700;}
.tc{
  padding:9px 10px;
  display:flex;align-items:center;
  border-right:1px solid rgba(255,255,255,.04);
  font-size:12px;min-height:40px;
}
.tc:last-child{border-right:none;}
.tc-edit{
  background:transparent;border:none;
  color:var(--text);font-size:12px;width:100%;outline:none;
  font-family:'Plus Jakarta Sans',sans-serif;
}
.tc-edit:focus{background:rgba(255,255,255,.04);border-radius:4px;padding:2px 4px;}
.tc-select{
  background:var(--surface3);border:1px solid var(--border2);
  border-radius:5px;color:var(--text);
  font-size:11px;padding:3px 6px;outline:none;
}

/* ── DATA PICKER ── */
.client-data-card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:20px;margin-bottom:18px;
}
.client-data-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;}
.client-data-item{display:flex;flex-direction:column;gap:5px;}
.client-data-label{font-size:10px;color:var(--text3);text-transform:uppercase;font-family:'JetBrains Mono',monospace;letter-spacing:.6px;}
.client-data-input{
  background:var(--surface2);
  border:1px solid var(--border2);
  border-radius:var(--r-sm);
  padding:9px 12px;color:var(--text);
  font-size:13px;width:100%;outline:none;
  transition:border-color .2s, box-shadow .2s;
  font-family:'Plus Jakarta Sans',sans-serif;
}
.client-data-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(240,165,0,.1);}
.data-picker-box{
  background:var(--surface2);
  border:1px solid rgba(240,165,0,.3);
  border-radius:var(--r-md);
  padding:16px 20px;
  display:flex;align-items:flex-end;gap:6px;flex-wrap:wrap;margin-top:4px;
}
.data-part{display:flex;flex-direction:column;gap:5px;align-items:center;}
.data-part label{font-size:9px;color:var(--text3);text-transform:uppercase;font-family:'JetBrains Mono',monospace;letter-spacing:1px;}
.data-part input{
  background:var(--surface3);
  border:1px solid var(--border2);
  border-radius:8px;padding:10px 8px;
  color:var(--text);font-size:22px;font-weight:800;
  font-family:'Plus Jakarta Sans',sans-serif;
  text-align:center;outline:none;
}
.data-part input:focus{border-color:var(--accent);}
.data-sep{font-size:24px;color:var(--text3);padding-bottom:10px;user-select:none;font-weight:300;}
.data-preview{margin-left:12px;padding-bottom:10px;font-size:12px;color:var(--accent);display:flex;flex-direction:column;gap:3px;font-weight:600;}

/* GANTT */
.gantt-wrap{border:1px solid var(--border);border-radius:var(--r-lg);overflow:hidden;background:var(--surface);margin-bottom:18px;}
.gantt-header{display:grid;grid-template-columns:280px 100px 100px 80px 100px 1fr;background:var(--surface2);border-bottom:1px solid var(--border);font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;}
.gh-cell{padding:12px;border-right:1px solid var(--border);}
.gantt-group{border-bottom:1px solid var(--border);}
.gantt-group-header{display:grid;grid-template-columns:280px 100px 100px 80px 100px 1fr;background:rgba(240,165,0,.05);cursor:pointer;padding:12px;align-items:center;transition:background .15s;}
.gantt-group-header:hover{background:rgba(240,165,0,.09);}
.gantt-row{display:grid;grid-template-columns:280px 100px 100px 80px 100px 1fr;border-bottom:1px solid rgba(255,255,255,.04);align-items:center;transition:background .12s;}
.gantt-row:hover{background:var(--surface2);}
.gc{padding:0 12px;height:var(--gantt-h);display:flex;align-items:center;border-right:1px solid rgba(255,255,255,.04);font-size:12px;}
.gc-edit{background:transparent;border:1px solid transparent;border-radius:5px;padding:4px 7px;color:var(--text);font-size:11px;width:100%;outline:none;font-family:'Plus Jakarta Sans',sans-serif;}
.gc-edit:focus{border-color:var(--border2);background:var(--surface2);}
.dot{width:8px;height:8px;border-radius:50%;margin-right:8px;flex-shrink:0;}
.bar-area{position:relative;height:var(--gantt-h);min-width:100%;overflow-x:auto;}
.gantt-bar{position:absolute;top:50%;transform:translateY(-50%);height:20px;border-radius:6px;display:flex;align-items:center;overflow:hidden;}
.gantt-bar-fill{height:100%;border-radius:6px 0 0 6px;opacity:.95;transition:width .5s ease-out;}
.today-line{position:absolute;top:0;bottom:0;width:2px;background:var(--accent4);opacity:.6;z-index:5;}

/* (remaining CSS already added above) */
</style>
</head>
<body>

<!-- LOGIN -->
<div id="loginModal" class="login-modal">
  <div class="login-content">
    <div class="login-logo-wrap">🏗️</div>
    <h2 class="login-title">Torre L'iris</h2>
    <p class="login-sub">Gestão Inteligente de Obras · v5</p>
    <input type="password" id="senhaInput" class="login-input" placeholder="Senha do administrador" onkeydown="if(event.key==='Enter') verificarSenha()">
    <div id="loginErr" style="color:var(--accent4);font-size:12px;margin:-2px 0 8px;display:none">❌ Senha incorreta.</div>
    <button class="login-btn btn-admin" onclick="verificarSenha()">🔐 Entrar como Administrador</button>
    <div class="login-sep">ou</div>
    <button class="login-btn btn-client" onclick="entrarComoCliente()">👁️ Visualizar como Cliente</button>
  </div>
</div>

<!-- MODAL -->
<div id="modalGenerico" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <div class="modal-title" id="modalTitulo"></div>
      <button class="modal-close" onclick="fecharModal()">&times;</button>
    </div>
    <div id="modalConteudo"></div>
  </div>
</div>

<!-- NOTIFICATION -->
<div id="notification" class="notification">
  <span id="notifIcon">✅</span>
  <span id="notifMsg"></span>
</div>

<div id="app"></div>

<script>
// ══════════════════════════════════════════════
// IA UTILS — declaradas no topo para ficarem disponíveis em todo o script
// ══════════════════════════════════════════════
var IA_LED_TABLE_REFERENCIA = [
  { desc: 'Fita de Led | 3000k | Sala | Cortineiro',             metros: 2.36  },
  { desc: 'Fita de Led | 3000k | Sala | Bar',                    metros: 6.79  },
  { desc: 'Fita de Led | 3000k | Gourmet | Estante',             metros: 7.28  },
  { desc: 'Fita de Led | 3000k | Gourmet | Hidromassagem',       metros: 1.50  },
  { desc: 'Fita de Led | 3000k | Lavabo',                        metros: 0.80  },
