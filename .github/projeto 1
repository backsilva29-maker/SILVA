// ── Exportar Excel ──
function bibCompExportarExcel() {
  const bib = bibCompDados();
  const wb = XLSX.utils.book_new();
  // Aba serviços
  const servRows = [['Código','Descrição','Unidade','Fonte','Mês Ref']];
  bib.composicoes.forEach(c=>servRows.push([c.codigo||'',c.descricao||'',c.unidade||'',c.fonte||'',c.mesRef||'']));
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(servRows), 'Serviços');
  // Aba insumos
  const insRows = [['Cód.Serviço','Código Insumo','Descrição','Unidade','Coef.TCPO','Preço Anterior','Preço Atual','Total','Var%']];
  bib.composicoes.forEach(c=>{
    (c.insumos||[]).forEach(i=>{
      const total=(i.coef||0)*(i.precoUnit||0);
      const varP=i.precoAnterior>0?((i.precoUnit-i.precoAnterior)/i.precoAnterior*100):null;
      insRows.push([c.codigo||'',i.codigo||'',i.descricao||'',i.unidade||'',i.coef||0,i.precoAnterior||0,i.precoUnit||0,total,varP!=null?varP.toFixed(2)+'%':'']);
    });
  });
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(insRows), 'Insumos');
  XLSX.writeFile(wb,'composicoes_tcpo.xlsx');
}

