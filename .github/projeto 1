function sbPor(id) {
  return {
    async get() {
      try {
        const r = await fetch(`${SUPABASE_URL}/rest/v1/torre_dados?id=eq.${id}&select=*`, {
          headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` }
        });
        if(!r.ok) return null;
        const data = await r.json();
        return data && data[0] ? JSON.parse(data[0].payload) : null;
      } catch(e) { return null; }
    },
    async set(payload) {
      try {
        const body = JSON.stringify({ id, payload: JSON.stringify(payload), updated_at: new Date().toISOString() });
        const r = await fetch(`${SUPABASE_URL}/rest/v1/torre_dados`, {
          method: 'POST',
          headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}`, 'Content-Type': 'application/json', 'Prefer': 'resolution=merge-duplicates' },
          body
        });
        return r.ok || r.status === 201 || r.status === 200;
      } catch(e) { return false; }
    }
  };
}

