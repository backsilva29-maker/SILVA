function exportarOrcamentoExcel() {
  const orc=orcDados();
  const bdiND=calcularBDITotal(orc.bdi.nd);
  const bdiD=calcularBDITotal(orc.bdi.d);
  const wb=XLSX.utils.book_new();

  // ABA 1 — Planilha Sintética
  const linhasSint=[
    ['PLANILHA ORÇAMENTÁRIA SINTÉTICA'],
    [`Obra: ${dados.titulo||''}`, '', '', `Endereço: ${dados.endereco||''}`],
    [`Referência: ${orc.refTabela} ${orc.refMes||''}`, '', '', `Data: ${fmtData(new Date())}`],
    [''],
    ['ITEM','CÓDIGO','DESCRIÇÃO','UND','QUANT.','P.UNIT. (R$)','TOTAL CD (R$)',`TOTAL BDI ND ${bdiND.toFixed(2)}% (R$)`,`TOTAL BDI D ${bdiD.toFixed(2)}% (R$)`],
  ];
  (orc.servicos||[]).forEach((sv,i)=>{
    if(sv._grupo){ linhasSint.push([`--- ${sv.nome} ---`]); return; }
    const tnd=(sv.totalCD||0)*(1+bdiND/100);
    const td=(sv.totalCD||0)*(1+bdiD/100);
    linhasSint.push([sv.item||i+1,sv.codigo,sv.nome,sv.unidade,sv.quantidade,sv.precoUnit,sv.totalCD,tnd,td]);
  });
  const totalCD=(orc.servicos||[]).filter(s=>!s._grupo).reduce((s,sv)=>s+(sv.totalCD||0),0);
  linhasSint.push(['','','','','','TOTAL CUSTO DIRETO',totalCD,'','']);
  linhasSint.push(['','','','','',`TOTAL c/ BDI NÃO DESONERADO (${bdiND.toFixed(2)}%)`,'',totalCD*(1+bdiND/100),'']);
  linhasSint.push(['','','','','',`TOTAL c/ BDI DESONERADO (${bdiD.toFixed(2)}%)`,'','',totalCD*(1+bdiD/100)]);
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(linhasSint),'Planilha Sintética');

  // ABA 2 — Composições Analíticas
  const linhasComp=[
    ['COMPOSIÇÕES ANALÍTICAS'],
    ['NRO','CÓDIGO','DESCRIÇÃO','UND','QUANT.','P.UNIT. (R$)','TOTAL (R$)','FONTE'],
  ];
  (orc.composicoes||[]).forEach((c,i)=>{
    linhasComp.push([i+1,c.codigo,c.descricao,c.unidade,c.quantidade,c.precoUnit,(c.quantidade||0)*(c.precoUnit||0),c.fonte]);
  });
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(linhasComp),'Composições Analíticas');

  // ABA 3 — BDI
  const linhasBDI=[
    ['MEMÓRIA DE CÁLCULO DO BDI'],[''],
    ['','NÃO DESONERADO','DESONERADO'],
    ['AC — Administração Central (%)',orc.bdi.nd.ac||0,orc.bdi.d.ac||0],
    ['S — Seguros (%)',orc.bdi.nd.s||0,orc.bdi.d.s||0],
    ['R — Riscos e Imprevistos (%)',orc.bdi.nd.r||0,orc.bdi.d.r||0],
    ['G — Garantia (%)',orc.bdi.nd.g||0,orc.bdi.d.g||0],
    ['DF — Despesas Financeiras (%)',orc.bdi.nd.df||0,orc.bdi.d.df||0],
    ['IR — Risco Adicional (%)',orc.bdi.nd.risk||0,orc.bdi.d.risk||0],
    ['L — Lucro (%)',orc.bdi.nd.l||0,orc.bdi.d.l||0],
    [''],
    ['BDI CALCULADO (%)',bdiND.toFixed(4),bdiD.toFixed(4)],
    ['Custo Direto (R$)',totalCD,totalCD],
    ['Total c/ BDI (R$)',totalCD*(1+bdiND/100),totalCD*(1+bdiD/100)],
  ];
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(linhasBDI),'BDI');

  // ABA 4 — Curva ABC
  const itensABC=(orc.composicoes||[]).filter(i=>(i.quantidade||0)*(i.precoUnit||0)>0);
  const totalABC=itensABC.reduce((s,i)=>s+(i.quantidade||0)*(i.precoUnit||0),0);
  const ordenadoABC=[...itensABC].sort((a,b)=>(b.quantidade*b.precoUnit)-(a.quantidade*a.precoUnit));
  let acum=0;
  const linhasABC=[['CURVA ABC'],['NRO','CÓDIGO','DESCRIÇÃO','UND','VALOR (R$)','PART. (%)','ACUM. (%)','CLASSE']];
  ordenadoABC.forEach((item,i)=>{
    const valor=(item.quantidade||0)*(item.precoUnit||0);
    const pct=totalABC>0?valor/totalABC*100:0;
    acum+=pct;
    linhasABC.push([i+1,item.codigo,item.descricao,item.unidade,valor,pct.toFixed(2),acum.toFixed(2),acum<=80?'A':acum<=95?'B':'C']);
  });
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(linhasABC),'Curva ABC');

  XLSX.writeFile(wb,`orcamento_${(dados.titulo||'obra').replace(/\s+/g,'_')}.xlsx`);
  mostrarNotificacao('Orçamento exportado em Excel!','success');
}

