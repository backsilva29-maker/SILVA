function mudarModo(modo) {
  modoAtual = modo;
  if(modo === 'projetos') {
    renderizarAdmin();
    setTimeout(() => renderizarProjetosAdmin(), 50);
    return;
  }
  renderizarAdmin();
  if(modo === 'ia') setTimeout(carregarModelosOllama, 100);
}
function mudarSubOrc(sub) { subModoOrc = sub; renderizarAdmin(); }
function renderizarConteudoAdmin() {
  switch(modoAtual) {
    case 'dashboard':    return renderizarDashboard();
    case 'projetos':     return renderizarProjetosAdmin();
    case 'dadosCliente': return renderizarDadosClienteAdmin();
    case 'iaOrcamento':  return renderizarIAOrcamento();
    case 'prevRealizado':return renderizarPrevRealizado();
    case 'cronograma':   return renderizarCronogramaAdmin();
    case 'levantamento': return renderizarLevantamentoMod();
    case 'orcamento':    return renderizarOrcamentoAdmin();
    case 'cotacao':      return renderizarCotacao();
    case 'fotos':        return renderizarFotosAdmin();
    case 'diario':       return renderizarDiarioAdmin();
    case 'ambientes':    return renderizarAmbientesAdmin();
    case 'arquivos':     return renderizarArquivosAdmin();
    case 'medicao':      return renderizarMedicaoAdmin();
    case 'alertas':      return renderizarAlertasAdmin();
    case 'ia':           return renderizarIAAdmin();
    case 'configuracoes':return renderizarConfiguracoesAdmin();
    default:             return renderizarDadosClienteAdmin();
  }
}

