// Lógica de importação de arquivos
window._impTempRows = null;
window._impTempFile = null;

async function impProcessarArquivo(file, tipo) {
  if(!file) return;
  const ext = file.name.split('.').pop().toLowerCase();
  if(tipo === 'xlsx' && !['xlsx','xls','csv'].includes(ext)) {
    mostrarNotificacao('Formato não suportado para Excel: .' + ext, 'error'); return;
  }
  if(tipo === 'pdf' && !['pdf','png','jpg','jpeg'].includes(ext)) {
    mostrarNotificacao('Formato não suportado para PDF: .' + ext, 'error'); return;
  }
  const sizeMB = (file.size / 1048576).toFixed(1);
  window._impTempFile = { file, tipo, ext };

  if(tipo === 'xlsx') {
    mostrarNotificacao('Lendo planilha...', 'syncing');
    try {
      if(typeof XLSX === 'undefined') await carregarScript('https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js');
      const reader = new FileReader();
      reader.onload = e => {
        try {
          const wb = XLSX.read(e.target.result, {type:'binary'});
          const ws = wb.Sheets[wb.SheetNames[0]];
          const rows = XLSX.utils.sheet_to_json(ws, {header:1, defval:''});
          window._impTempRows = rows;
          // Detectar cabeçalho
          const cab = encontrarCabecalho(rows);
          const headerRow = cab ? cab.headerRow : rows[0] || [];
          window._impHeaderIndex = cab ? cab.headerIndex : 0;
          const colunas = detectarColunas(headerRow);
          window._impColunasDetectadas = colunas;
          // Montar grid de mapeamento
          const opcoes = headerRow.map((c,idx)=>`<option value="${idx}">${c || 'Col '+(idx+1)}</option>`).join('');
          const campos = [
            {id:'mapC_codigo',   label:'Código SINAPI'},
            {id:'mapC_descricao',label:'Descrição'},
            {id:'mapC_unidade',  label:'Unidade'},
            {id:'mapC_quantidade',label:'Quantidade'},
            {id:'mapC_etapa',    label:'Etapa / Grupo'},
            {id:'mapC_precoUnit',label:'Preço Unitário'},
          ];
          const grid = document.getElementById('xlsMapGrid');
          if(grid) {
            grid.style.gridTemplateColumns = 'repeat(3,1fr)';
            grid.innerHTML = campos.map(f=>`
              <div>
                <div style="font-size:10px;color:var(--text3);margin-bottom:4px;text-transform:uppercase">${f.label}</div>
                <select id="${f.id}" class="crud-select" style="font-size:11px">
                  <option value="-1">— Ignorar —</option>
                  ${opcoes}
                </select>
              </div>`).join('');
            // Pré-selecionar detectados
            const m = {'mapC_codigo':colunas.codigo,'mapC_descricao':colunas.descricao,'mapC_unidade':colunas.unidade,'mapC_precoUnit':colunas.preco};
            setTimeout(()=>{ Object.entries(m).forEach(([id,v])=>{ const el=document.getElementById(id); if(el&&v>=0) el.value=v; }); }, 80);
          }
          document.getElementById('xlsMapeamento').style.display = 'block';
          const prev = document.getElementById('xlsPreview');
          if(prev) prev.innerHTML = `<div style="background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3);border-radius:8px;padding:10px;font-size:11px;color:var(--accent3)">
            ✅ ${rows.length} linhas detectadas — configure o mapeamento acima</div>`;
          // Registrar arquivo
          if(!dados._arquivosImportados) dados._arquivosImportados = [];
          dados._arquivosImportados.push({nome:file.name, tamanho:sizeMB+' MB', hora:new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}), tipo:'xlsx'});
        } catch(err) { mostrarNotificacao('Erro ao ler planilha: '+err.message,'error'); }
      };
      reader.readAsBinaryString(file);
    } catch(err) { mostrarNotificacao('Erro: '+err.message,'error'); }
  } else {
    // PDF/Imagem
    if(!dados._arquivosImportados) dados._arquivosImportados = [];
    dados._arquivosImportados.push({nome:file.name, tamanho:sizeMB+' MB', hora:new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}), tipo:'pdf'});
    const prev = document.getElementById('pdfDropPreview');
    if(prev) prev.innerHTML = `<div style="background:rgba(244,63,94,.1);border:1px solid rgba(244,63,94,.3);border-radius:8px;padding:10px;font-size:11px;color:#fb7185">
      📄 ${file.name} (${sizeMB} MB)</div>`;
    if(ext === 'pdf') {
      document.getElementById('pdfIABox').style.display = 'block';
      window._impTempPDFFile = file;
    } else {
      mostrarNotificacao('Imagem registrada com sucesso!', 'success');
    }
    mudarSubOrc('importarArquivos');
  }
}

function impConfirmarExcel() {
  const rows = window._impTempRows;
  if(!rows) { mostrarNotificacao('Nenhuma planilha carregada','error'); return; }
  const gi = v => { const el = document.getElementById(v); return el ? parseInt(el.value) : -1; };
  const colunas = { codigo:gi('mapC_codigo'), descricao:gi('mapC_descricao'), unidade:gi('mapC_unidade'), quantidade:gi('mapC_quantidade'), etapa:gi('mapC_etapa'), precoUnit:gi('mapC_precoUnit') };
  if(colunas.descricao < 0) { mostrarNotificacao('Selecione ao menos a coluna Descrição','error'); return; }
  const orc = orcDados();
  let count = 0;
  for(let i = (window._impHeaderIndex||0)+1; i < rows.length; i++) {
    const r = rows[i];
    if(!r || r.length === 0) continue;
    const desc = colunas.descricao>=0?(r[colunas.descricao]||'').toString().trim():'';
    if(!desc) continue;
    orc.composicoes.push({
      id: uid(),
      codigo:   colunas.codigo>=0?   (r[colunas.codigo]||'').toString().trim():'',
      descricao: desc,
      unidade:  colunas.unidade>=0?  (r[colunas.unidade]||'').toString().trim():'un',
      quantidade:colunas.quantidade>=0? parseFloat((r[colunas.quantidade]||'').toString().replace(',','.'))||0:0,
      etapa:    colunas.etapa>=0?    (r[colunas.etapa]||'').toString().trim():'',
      precoUnit:colunas.precoUnit>=0? parseFloat((r[colunas.precoUnit]||'').toString().replace(/R\$\s*/g,'').replace(/\./g,'').replace(',','.'))||0:0,
      fonte: orc.refTabela||'Importado'
    });
    count++;
  }
  document.getElementById('xlsMapeamento').style.display = 'none';
  window._impTempRows = null;
  agendarSync();
  mostrarNotificacao(`✅ ${count} itens importados para Levantamento!`, 'success');
  mudarSubOrc('levantamento');
}

function impConfirmarExcelTabela() {
  const rows = window._impTempRows;
  if(!rows) { mostrarNotificacao('Nenhuma planilha carregada','error'); return; }
  const gi = v => { const el = document.getElementById(v); return el ? parseInt(el.value) : -1; };
  const colunas = { codigo:gi('mapC_codigo'), descricao:gi('mapC_descricao'), unidade:gi('mapC_unidade'), preco:gi('mapC_precoUnit') };
  if(colunas.descricao < 0) { mostrarNotificacao('Selecione ao menos a coluna Descrição','error'); return; }
  importarTabela(rows, window._impHeaderIndex||0, colunas);
  document.getElementById('xlsMapeamento').style.display = 'none';
  window._impTempRows = null;
}

function impUsarIAPDF() {
  document.getElementById('pdfIABox').style.display = 'none';
  if(window._impTempPDFFile) {
    abrirUploadPDFIA();
    // Aguarda o modal abrir, depois injeta o arquivo e processa
    setTimeout(() => {
      iaLeituraProcessar(window._impTempPDFFile);
    }, 300);
  }
}

function impCancelar() {
  window._impTempRows = null;
  document.getElementById('xlsMapeamento').style.display = 'none';
}

function impRemover(i) {
  if(!dados._arquivosImportados) return;
  dados._arquivosImportados.splice(i,1);
  mudarSubOrc('importarArquivos');
}

