function renderizarPrevRealizado() {
  const orc = orcDados();
  const bdiND = calcularBDITotal(orc.bdi.nd);
  const servicos = (orc.servicos||[]).filter(s=>!s._grupo);
  const totalPrev = servicos.reduce((s,sv)=>s+(sv.totalCD||0)*(1+bdiND/100),0);

  // Get medicao data to compute realizado
  const boletins = (dados.medicao&&dados.medicao.boletins)||[];
  const totalReal = boletins.reduce((s,b)=>s+(b.valorTotal||0),0);
  const progFisico = calcularProgressoGeral();
  const desvio = totalPrev>0 ? ((totalReal - totalPrev*progFisico/100)/totalPrev*100) : 0;

  return `
  <div class="page-header">
    <div>
      <div class="page-title">⚖️ Previsto × Realizado</div>
      <div class="page-sub">Comparativo financeiro — desvios e variações por etapa</div>
    </div>
    <button class="btn btn-ghost" onclick="exportarOrcamentoExcel()">📥 Exportar</button>
  </div>

  <!-- Summary cards -->
  <div class="dashboard-grid" style="grid-template-columns:repeat(4,1fr)">
    <div class="dash-card">
      <div class="accent-line" style="background:var(--accent2)"></div>
      <span class="d-icon">📋</span>
      <div class="d-val" style="color:var(--accent2)">${fmtR(totalPrev)}</div>
      <div class="d-label">Total Orçado</div>
      <div class="d-delta neutral">Orçamento base</div>
    </div>
    <div class="dash-card">
      <div class="accent-line" style="background:var(--accent3)"></div>
      <span class="d-icon">✅</span>
      <div class="d-val" style="color:var(--accent3)">${fmtR(totalReal)}</div>
      <div class="d-label">Total Medido</div>
      <div class="d-delta ${totalReal<=totalPrev?'up':'down'}">${boletins.length} boletim(ns)</div>
    </div>
    <div class="dash-card">
      <div class="accent-line" style="background:${desvio>5?'var(--accent4)':desvio>0?'var(--accent)':'var(--accent3)'}"></div>
      <span class="d-icon">📊</span>
      <div class="d-val" style="color:${desvio>5?'var(--accent4)':desvio>0?'var(--accent)':'var(--accent3)'}">${desvio.toFixed(1)}%</div>
      <div class="d-label">Desvio Financeiro</div>
      <div class="d-delta ${desvio>5?'down':desvio>0?'neutral':'up'}">${desvio>0?'Acima do previsto':desvio<0?'Abaixo do previsto':'Dentro do orçado'}</div>
    </div>
    <div class="dash-card">
      <div class="accent-line" style="background:var(--accent)"></div>
      <span class="d-icon">⏱️</span>
      <div class="d-val" style="color:var(--accent)">${progFisico}%</div>
      <div class="d-label">Progresso Físico</div>
      <div class="d-delta neutral">Previsto financeiro: ${totalPrev>0?fmtR(totalPrev*progFisico/100):'—'}</div>
    </div>
  </div>

  <!-- Table by group -->
  <div class="pvr-wrap">
    <div class="pvr-header">
      <div class="tc">Etapa / Grupo</div>
      <div class="tc">Previsto (R$)</div>
      <div class="tc">Realizado (R$)</div>
      <div class="tc">Progresso</div>
      <div class="tc" style="border-right:none">Desvio</div>
    </div>
    ${dados.grupos.length===0?`<div style="padding:32px;text-align:center;color:var(--text3);font-size:12px">Adicione grupos no Cronograma e registros de medição para visualizar o comparativo</div>`:''}
    ${dados.grupos.map((g,gi)=>{
      const prog = calcularProgressoGrupo(g);
      // Estimate previsto per group proportionally
      const prevG = servicos.length>0 ? totalPrev/Math.max(dados.grupos.length,1) : 0;
      const realG = boletins.filter(b=>b.grupoId===g.id).reduce((s,b)=>s+(b.valorTotal||0),0);
      const desvG = prevG>0 ? ((realG - prevG*prog/100)/prevG*100) : 0;
      return `
      <div class="pvr-row">
        <div class="tc" style="gap:7px">
          <div style="width:8px;height:8px;border-radius:50%;background:${g.cor};flex-shrink:0"></div>
          <span style="font-size:12px">${g.nome}</span>
        </div>
        <div class="tc" style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--accent2)">${fmtR(prevG)}</div>
        <div class="tc" style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--accent3)">${realG>0?fmtR(realG):'—'}</div>
        <div class="tc" style="gap:8px">
          <div class="pvr-bar-wrap"><div class="pvr-bar" style="width:${prog}%;background:${g.cor}"></div></div>
          <span style="font-size:11px;font-weight:600;min-width:28px">${prog}%</span>
        </div>
        <div class="tc" style="border-right:none">
          <span class="${desvG>5?'pvr-desvio-bad':desvG>0?'pvr-desvio-warn':'pvr-desvio-ok'}">
            ${realG>0?(desvG>0?'+':'')+desvG.toFixed(1)+'%':'—'}
          </span>
        </div>
      </div>`;
    }).join('')}
    ${dados.grupos.length>0?`
    <div class="pvr-row" style="background:rgba(14,201,138,.05);font-weight:700">
      <div class="tc"><span style="font-size:12px;font-weight:700">Total</span></div>
      <div class="tc" style="font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--accent2);font-weight:700">${fmtR(totalPrev)}</div>
      <div class="tc" style="font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--accent3);font-weight:700">${totalReal>0?fmtR(totalReal):'—'}</div>
      <div class="tc" style="font-weight:700">${progFisico}% concluído</div>
      <div class="tc" style="border-right:none"><span class="${desvio>5?'pvr-desvio-bad':desvio>0?'pvr-desvio-warn':'pvr-desvio-ok'}">${(desvio>0?'+':'')+desvio.toFixed(1)}%</span></div>
    </div>`:''}
  </div>

  <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:16px 20px;margin-top:4px">
    <div style="font-weight:700;font-size:13px;margin-bottom:10px">💡 Como usar este módulo</div>
    <div style="font-size:12px;color:var(--text2);line-height:1.8">
      1. Preencha o orçamento na aba <strong>Planilha Sintética</strong> com custos previstos.<br>
      2. Registre medições realizadas na aba <strong>Medição de Obra</strong> associando ao grupo.<br>
      3. O desvio é calculado automaticamente: <strong>% desvio = (realizado − previsto×progresso) / previsto × 100</strong>.<br>
      4. Desvio verde = dentro do orçado · Amarelo = até 5% acima · Vermelho = mais de 5% acima.
    </div>
  </div>`;
}

