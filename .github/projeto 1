// Extrai áreas dos ambientes do texto do PDF para contexto global
function iaExtrairAreas(texto) {
  const linhas = texto.split(/\n|\f/);
  const areas = {};
  // Padrão: "NOME DO AMBIENTE A=XX.XXm²" ou sequencial
  const reInline = /([A-ZÇÃÕÉÁÍÓÚ][A-ZÇÃÕÉÁÍÓÚa-záéíóúãõêâôçàü\s\/]{2,35})\s+A=([\d,.]+)m²/g;
  let m;
  while((m=reInline.exec(texto))!==null) {
    const nome = m[1].trim();
    const area = parseFloat(m[2].replace(',','.'));
    if(nome.length>2 && nome.length<40 && !nome.match(/^\d/) && area>0) {
      if(!areas[nome] || area > areas[nome]) areas[nome] = area;
    }
  }
  // Busca sequencial: nome na linha, A=xx na próxima
  for(let i=0;i<linhas.length-1;i++) {
    const nome = linhas[i].trim();
    const proxima = linhas[i+1].trim();
    const mArea = proxima.match(/^A=([\d,.]+)m²$/);
    if(mArea && nome.length>2 && nome.length<40 && nome.match(/^[A-ZÁÉÍÓÚÃÕÇ]/)) {
      const area = parseFloat(mArea[1].replace(',','.'));
      if(area>0 && !areas[nome]) areas[nome]=area;
    }
  }
  if(Object.keys(areas).length===0) return '';
  const totalArea = Object.values(areas).reduce((s,v)=>s+v,0);
  const linhasAreas = Object.entries(areas)
    .filter(([k])=>!k.match(/Rodrigues|Kalume|Caio|ARQ/i))
    .map(([k,v])=>`${k}: ${v}m²`);

  // Detecta e adiciona tabela de fitas de LED se presente no texto
  const ledTable = iaExtrairFitasLED(texto);

  return linhasAreas.join('\n')
    + `\nÁREA TOTAL APROXIMADA: ${totalArea.toFixed(2)}m²`
    + (ledTable ? '\n\n' + ledTable : '');
}

// Reconstrói tabela de fitas de LED do texto extraído
function iaExtrairFitasLED(texto) {
  // Busca sequência: descrição de fita seguida de medida
  const tokens = texto.match(/(?:Fita de Led[^\n\r]{3,60})|(?:[\d]+[,\.][\d]{1,2}\s*m(?:\b|\s))/g) || [];
  if(tokens.length < 4) return '';
  const pares = [];
  let desc = null;
  tokens.forEach(t => {
    const isFita = t.toLowerCase().startsWith('fita de led');
    if(isFita) { desc = t.trim(); }
    else if(desc) {
      const val = parseFloat(t.replace(',','.').replace(/m.*/,''));
      if(val > 0 && val < 50) { // sanidade: fita > 50m provavelmente é cota
        pares.push(`${desc}: ${val}m`);
        desc = null;
      }
    }
  });
  if(pares.length < 3) return '';
  return '=== FITAS DE LED (tabela do projeto) ===\n' + pares.join('\n');
}


// Repara JSON truncado fechando arrays e objetos abertos
function iaRepararJSON(str) {
  // Remove vírgula final antes de fechar
  str = str.replace(/,\s*([}\]])/g, '$1');
  // Conta abertura e fechamento de { e [
  let obj=0, arr=0, inStr=false, esc=false;
  for(let i=0;i<str.length;i++) {
    const c=str[i];
    if(esc){esc=false;continue;}
    if(c==='\\'&&inStr){esc=true;continue;}
    if(c==='"'&&!esc){inStr=!inStr;continue;}
    if(inStr) continue;
    if(c==='{') obj++;
    else if(c==='}') obj--;
    else if(c==='[') arr++;
    else if(c===']') arr--;
  }
  // Se estava no meio de uma string, fecha
  if(inStr) str+='"';
  // Fecha objetos incompletos
  while(arr>0){str+=']';arr--;}
  while(obj>0){str+='}';obj--;}
  // Remove vírgula final de novo após fechar
  str = str.replace(/,\s*([}\]])/g, '$1');
  return str;
}

// Pré-processa texto do PDF: reconstrói tabela de fitas de LED e remove ruído de cotas
function iaLimparTextoPDF(texto) {
  // Coleta todas as fitas de LED e seus metros do texto
  const descricoes = [];
  const medidas = [];

  // Captura descrições de fitas
  const reDesc = /Fita de Led[^\n]+/g;
  let m;
  while((m=reDesc.exec(texto))!==null) descricoes.push(m[0].trim());

  // Captura medidas no formato X,XXm ou X.XXm próximas às fitas
  const reMed = /([\d]+[,\.][\d]+)\s*m\b/g;
  // Busca na seção de legenda (após "PLANTA DE ILUMINAÇÃO" ou "LEGENDA")
  const secaoLeg = texto.match(/(?:PLANTA DE ILUMINAÇÃO|LEGENDA)[\s\S]{0,200}?((?:Fita de Led[\s\S]*?)+)(?:ENDEREÇO|CONTATO|PROJETO)/);
  if(secaoLeg) {
    const legTexto = secaoLeg[1];
    // Reconstrói: pega fitas e medidas em sequência
    const tokens = legTexto.match(/(?:Fita de Led[^\n]+)|(?:[\d]+[,\.][\d]+\s*m)/g) || [];
    const pares = [];
    let descAtual = null;
    tokens.forEach(t => {
      if(t.startsWith('Fita')) { descAtual = t.trim(); }
      else if(descAtual) {
        pares.push({ desc: descAtual, med: parseFloat(t.replace(',','.').replace('m','')) });
        descAtual = null;
      }
    });
    if(pares.length > 5) {
      // Substitui no texto original a seção de fitas por versão limpa
      const ledLimpo = '=== FITAS DE LED (tabela reconstruída) ===\n' +
        pares.map(p=>`Fita de Led: ${p.desc} | ${p.med}m`).join('\n');
      // Remove a seção bagunçada e adiciona a limpa
      texto = texto.replace(/Fita de Led[\s\S]*?(?=ENDEREÇO|CONTATO|PROJETO)/, ledLimpo + '\n\n');
    }
  }
  return texto;
}


async function iaCallGroq(apiKey, modelo, modo, texto, tabela, isPrimeira=true) {
  const prompts = {
    orcamento: `Você é orçamentista especialista em construção civil brasileiro (padrão ${tabela}).
Analise APENAS as pranchas fornecidas e extraia os serviços COM AS ESPECIFICAÇÕES EXATAS do documento.
REGRAS OBRIGATÓRIAS:
1. Use a descrição EXATA dos materiais como está no documento (ex: "Revestimento YORK WH HARD 90x90cm Portinari Cód.63059", NÃO "Piso cerâmico")
2. Use as áreas dos ambientes para calcular quantidades: piso/revestimento = área + 10% perda
3. Pintura: some as áreas de parede (perímetro × pé-direito 2,70m), divida por rendimento 10m²/L, multiplique por 2 demãos
4. Conte EXATAMENTE as unidades listadas nas legendas (portas, luminárias, pontos, splits)
5. Para rodapés: use os metros lineares informados no documento
6. Para fitas de LED e perfis: use os metros informados nas legendas
7. NUNCA generalize — preserve a especificação completa de cada item
8. NUNCA retorne quantidade 0
9. Não repita itens já extraídos de pranchas anteriores — foque no que é NOVO nesta prancha
Retorne SOMENTE JSON sem texto extra:
{"itens":[{"codigo":"SINAPI se souber","descricao":"ESPECIFICAÇÃO EXATA do documento","unidade":"m²/ml/un/L","quantidade":0.00,"precoUnit":0,"etapa":"Pisos|Revestimentos|Forro/Gesso|Pintura|Elétrica|Hidráulica|Iluminação|Marcenaria|Climatização|Rodapés","obs":"memória: como calculou"}]}`,

    levantamento: `Você é orçamentista especialista em construção civil brasileiro.
Analise APENAS as pranchas fornecidas e levante os materiais COM AS ESPECIFICAÇÕES EXATAS do documento.
REGRAS OBRIGATÓRIAS:
1. Use a descrição EXATA dos materiais (ex: "Fita de Led 3000k Sala Cortineiro 2,36m", NÃO "Fita LED")
2. Use as áreas dos ambientes para calcular: piso/revestimento = área + 10%, forro = área, rodapé = metros lineares do documento
3. Tintas: some áreas de parede de cada ambiente (perímetro × 2,70m), 2 demãos, rendimento 10m²/L → litros
4. Luminárias/spots/arandelas: use EXATAMENTE as quantidades listadas nas legendas do projeto
5. Fitas de LED: copie EXATAMENTE cada linha da legenda — descrição e metragem são pares fixos (ex: 'Fita de Led 3000k Sala Cortineiro' corresponde a '2,36m' — NÃO troque os valores entre itens)
6. Pontos hidráulicos/elétricos/gás: conte cada ponto listado no documento
7. Splits: use o modelo e BTU exatos informados
8. NUNCA generalize — preserve especificação completa
9. NUNCA retorne quantidade 0
10. Não repita itens de pranchas anteriores — foque no que é NOVO nesta prancha
Retorne SOMENTE JSON sem texto extra:
{"itens":[{"codigo":"","descricao":"ESPECIFICAÇÃO EXATA do documento","unidade":"m²/ml/un/L","quantidade":0.00,"precoUnit":0,"etapa":"Ambiente ou Etapa","obs":"memória de cálculo"}]}`,

    composicoes: `Você é orçamentista especialista em construção civil brasileiro (TCPO/${tabela}).
Monte composições analíticas dos serviços identificados nesta prancha com insumos e coeficientes TCPO.
Use as especificações EXATAS do documento. Coeficientes TCPO obrigatórios. NUNCA coloque coeficiente 0.
Não repita composições já listadas em pranchas anteriores.
Retorne SOMENTE JSON sem texto extra:
{"composicoes":[{"codigo":"","descricao":"serviço com especificação exata","unidade":"m²","quantidade":0.00,"insumos":[{"codigo":"","descricao":"insumo","unidade":"un","coef":0.0000,"precoUnit":0,"obs":"ref TCPO"}]}]}`
  };

  const resp = await fetch(GROQ_URL, {
    method:'POST',
    headers:{'Content-Type':'application/json','Authorization':'Bearer '+apiKey},
    body: JSON.stringify({
      model: modelo,
      messages:[{role:'system',content:prompts[modo]},{role:'user',content:'PRANCHAS DO PROJETO:\n'+texto}],
      temperature:0.05,
      max_tokens:8000
    })
  });
  if(!resp.ok) { const e=await resp.json().catch(()=>({})); throw new Error(e.error?.message||'HTTP '+resp.status); }
  const data = await resp.json();
  const txt  = data.choices?.[0]?.message?.content||'';
  // Tenta extrair JSON completo, recupera JSON truncado
  let jsonStr = '';
  const match = txt.match(/\{[\s\S]*\}/);
  if(!match) throw new Error('IA não retornou JSON válido.');
  jsonStr = match[0];
  // Tenta parse direto
  try { return JSON.parse(jsonStr); } catch(e) {
    // JSON truncado — fecha arrays/objetos abertos
    jsonStr = iaRepararJSON(jsonStr);
    try { return JSON.parse(jsonStr); } catch(e2) {
      throw new Error('JSON inválido mesmo após reparo: '+e2.message);
    }
  }
}

