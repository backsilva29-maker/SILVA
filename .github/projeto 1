function levMatAdicionarItem() {
  levMatDados().itens.push({ id:uid(), descricao:'', unidade:'un', quantidade:0, ambiente:'' });
  agendarSync(); mudarModo('levantamento');
}
function levMatToggle(i, checked) { if(checked) _levMat_sel.add(i); else _levMat_sel.delete(i); mudarModo('levantamento'); }
function levMatToggleTodos(idxs, checked) { idxs.forEach(i=>checked?_levMat_sel.add(i):_levMat_sel.delete(i)); mudarModo('levantamento'); }
function levMatExcluir(i) { if(confirm('Excluir item?')) { levMatDados().itens.splice(i,1); _levMat_sel.delete(i); agendarSync(); mudarModo('levantamento'); } }
function levMatExcluirSel() {
  if(!_levMat_sel.size||!confirm(`Excluir ${_levMat_sel.size} item(s)?`)) return;
  levMatDados().itens = levMatDados().itens.filter((_,i)=>!_levMat_sel.has(i));
  _levMat_sel.clear(); agendarSync(); mudarModo('levantamento');
  mostrarNotificacao('Itens excluídos!','success');
}
function levMatExcluirTudo() {
  const n = levMatDados().itens.length;
  if(!n||!confirm(`Excluir TODOS os ${n} materiais?`)) return;
  levMatDados().itens = []; _levMat_sel.clear(); agendarSync(); mudarModo('levantamento');
  mostrarNotificacao(`${n} item(s) excluído(s)!`,'success');
}
function levMatEnviarCotacao() {
  const lev = levMatDados();
  const selecionados = lev.itens.filter((_,i)=>_levMat_sel.has(i));
  if(!selecionados.length) return;
  const cot = cotacaoDados();
  selecionados.forEach(it => {
    if(!cot.itens.find(c=>c.descricao===it.descricao)) {
      cot.itens.push({ id:uid(), descricao:it.descricao, unidade:it.unidade, quantidade:it.quantidade, ambiente:it.ambiente, precos:{} });
    }
  });
  _levMat_sel.clear(); agendarSync(); mudarModo('cotacao');
  mostrarNotificacao(`${selecionados.length} item(s) enviado(s) para Cotação!`,'success');
}

function exportarLevantamentoCotacao() {
  const itens = levMatDados().itens;
  if(!itens.length) { mostrarNotificacao('Nenhum item no levantamento.','error'); return; }
  const wb = XLSX.utils.book_new();
  const header = [['Nº','Descrição do Material','Ambiente / Etapa','Unidade','Quantidade','Preço Unit. (R$)','Total (R$)','Fornecedor','Obs.']];
  const rows = itens.map((it,i)=>[i+1, it.descricao||'', it.ambiente||'', it.unidade||'', it.quantidade||0, '', '', '', '']);
  const ws = XLSX.utils.aoa_to_sheet([...header, ...rows]);
  // Estilo da coluna de preço e total em branco (destaque)
  ws['!cols'] = [{wch:5},{wch:45},{wch:20},{wch:8},{wch:10},{wch:14},{wch:14},{wch:22},{wch:20}];
  XLSX.utils.book_append_sheet(wb, ws, 'Levantamento Cotação');
  XLSX.writeFile(wb, `levantamento_cotacao_${dados.titulo||'obra'}.xlsx`);
  mostrarNotificacao('Planilha de cotação exportada!','success');
}

