function limparChat() {
  chatHistory=[];_chatContextInjetado=false;
  const msgs=document.getElementById('chatMsgs');
  if(msgs) msgs.innerHTML='<div class="chat-msg system">Chat limpo</div>';
}
async function enviarMensagemIA(texto) {
  texto=(texto||'').trim();
  if(!texto) return;
  const provider=getChatProvider();
  if(provider==='none'){mostrarNotificacao('Configure o Groq ou instale Ollama!','error');return;}
  const input=document.getElementById('chatInput'), msgs=document.getElementById('chatMsgs');
  if(!msgs) return;
  if(input){input.value='';input.style.height='auto';}
  msgs.innerHTML+=`<div class="chat-msg user">${texto.replace(/</g,'&lt;')}</div>`;
  const loadId='load_'+uid();
  msgs.innerHTML+=`<div class="chat-msg loading" id="${loadId}"><span style="animation:pulse 1s infinite">●●●</span> ${provider==='groq'?'Groq':'Ollama'} pensando...</div>`;
  msgs.scrollTop=msgs.scrollHeight;
  if(!_chatContextInjetado){chatHistory=[{role:'system',content:getContextoObra()}];_chatContextInjetado=true;}
  chatHistory.push({role:'user',content:texto});
  try {
    let resposta='';
    if(provider==='ollama'){
      const r=await fetch(OLLAMA_URL+'/api/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:ollamaModel,messages:chatHistory,stream:false})});
      if(!r.ok) throw new Error('Ollama HTTP '+r.status);
      resposta=(await r.json()).message?.content||'';
    } else {
      const r=await fetch(GROQ_URL,{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+getGroqKey()},body:JSON.stringify({model:groqModel,messages:chatHistory,temperature:0.4,max_tokens:1500})});
      if(!r.ok){const err=await r.json().catch(()=>({error:{message:r.statusText}}));throw new Error(err.error?.message||'Groq HTTP '+r.status);}
      resposta=(await r.json()).choices?.[0]?.message?.content||'';
    }
    chatHistory.push({role:'assistant',content:resposta});
    const loadEl=document.getElementById(loadId);if(loadEl) loadEl.remove();
    const tag=provider==='groq'?'<span style="font-size:9px;color:var(--accent2);float:right">⚡ Groq</span>':'<span style="font-size:9px;color:var(--accent3);float:right">🦙 Ollama</span>';
    msgs.innerHTML+=`<div class="chat-msg ai">${resposta.replace(/</g,'&lt;').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\n/g,'<br>')}${tag}</div>`;
  } catch(e) {
    const loadEl=document.getElementById(loadId);
    if(loadEl) loadEl.innerHTML=`<span style="color:var(--accent4)">❌ ${e.message}</span>`;
    if(provider==='ollama') ollamaOnline=false;
  }
  msgs.scrollTop=msgs.scrollHeight;
}
