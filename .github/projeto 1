function atualizarDataPartes() {
  let dia=parseInt(document.getElementById('inputDia').value)||1;
  let mes=parseInt(document.getElementById('inputMes').value)||1;
  let ano=parseInt(document.getElementById('inputAno').value)||2026;
  dia=Math.min(Math.max(dia,1),31); mes=Math.min(Math.max(mes,1),12); ano=Math.min(Math.max(ano,2020),2040);
  dados.dataInicio=`${ano}-${String(mes).padStart(2,'0')}-${String(dia).padStart(2,'0')}`;
  agendarSync();
  const prev=document.getElementById('dataPreview');
  if(prev) prev.innerHTML=`<span>📅 ${fmtData(getDataInicio())}</span><span style="color:var(--text2)">Término: ${calcularPrevisao()}</span>`;
}

