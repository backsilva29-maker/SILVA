function recalcServico(i) {
  const sv = orcDados().servicos[i];
  if(!sv) return;
  sv.totalCD = (sv.quantidade||0)*(sv.precoUnit||0);
}
function adicionarServico() {
  const orc = orcDados();
  const n = orc.servicos.filter(s=>!s._grupo).length+1;
  orc.servicos.push({ id:uid(), item:n, codigo:'', nome:'', unidade:'', quantidade:0, precoUnit:0, totalCD:0, fonte:orc.refTabela });
  agendarSync(); mudarSubOrc('sintetico');
}
function excluirServico(i) {
  if(confirm('Excluir?')){ orcDados().servicos.splice(i,1); agendarSync(); mudarSubOrc('sintetico'); }
}
function gerarSinteticoAutomatic() {
  const orc = orcDados();
  if(!orc.composicoes||orc.composicoes.length===0){ mostrarNotificacao('Cadastre itens no Levantamento primeiro','error'); return; }
  const grupos = {};
  orc.composicoes.forEach(c=>{
    const etapa = c.etapa||'Geral';
    if(!grupos[etapa]) grupos[etapa]=[];
    grupos[etapa].push(c);
  });
  orc.servicos = [];
  let itemN = 1;
  Object.entries(grupos).forEach(([etapa, itens])=>{
    orc.servicos.push({ _grupo:true, nome:etapa });
    itens.forEach(c=>{
      orc.servicos.push({ id:uid(), item:itemN++, codigo:c.codigo, nome:c.descricao, unidade:c.unidade, quantidade:c.quantidade, precoUnit:c.precoUnit||0, totalCD:(c.quantidade||0)*(c.precoUnit||0), fonte:c.fonte||orc.refTabela });
    });
  });
  agendarSync(); mudarSubOrc('sintetico'); mostrarNotificacao('Planilha gerada automaticamente!','success');
}

