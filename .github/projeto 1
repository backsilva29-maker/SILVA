        <div style="font-size:11px;color:var(--text3)">Planta arquitetônica · Memorial · Especificações</div>
      </div>
      <div id="levIASt"></div>
      <div id="levIARes"></div>
    </div>`);
}

async function levIAProcessar(file) {
  if(!file) return;
  const st = document.getElementById('levIASt');
  const res = document.getElementById('levIARes');
  const apiKey = (document.getElementById('levIAKey')?.value||getGroqKey()).trim();
  const modelo = document.getElementById('levIAModel')?.value||groqModel;
  if(!apiKey) { if(st) st.innerHTML=`<div style="color:var(--accent4);font-size:12px;padding:8px">❌ Configure a chave Groq.</div>`; return; }

  const isPDF = file.name.toLowerCase().endsWith('.pdf');
  if(st) st.innerHTML=`<div style="display:flex;align-items:center;gap:10px;background:var(--surface2);border-radius:10px;padding:14px"><div style="width:18px;height:18px;border:2px solid var(--accent5);border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite;flex-shrink:0"></div><div id="levIAProgress" style="font-size:12px;color:var(--text2)">Carregando arquivo...</div></div>`;
  const setP = m => { const e=document.getElementById('levIAProgress'); if(e) e.textContent=m; };

  try {
    let textosPorPagina = [];
    if(isPDF) {
      if(typeof pdfjsLib==='undefined') {
        await carregarScript('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js');
        pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
      }
      const pdf = await pdfjsLib.getDocument({data:await file.arrayBuffer()}).promise;
      for(let p=1;p<=Math.min(pdf.numPages,50);p++) {
        setP(`📄 Extraindo pág. ${p}/${pdf.numPages}...`);
        const pg=await pdf.getPage(p); const tc=await pg.getTextContent();
        const txt=tc.items.map(i=>i.str).join(' ').trim();
        if(txt.length>30) textosPorPagina.push({pag:p,txt});
      }
    } else {
      const ab=await file.arrayBuffer();
      const wb=XLSX.read(ab,{type:'array'});
      const rows=XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]],{header:1,defval:''});
      textosPorPagina=[{pag:1,txt:rows.slice(0,200).map(r=>r.map(c=>(c||'').toString().trim()).filter(Boolean).join(' | ')).join('\n')}];
    }
    if(!textosPorPagina.length) throw new Error('Não foi possível extrair texto.');

    const contextoAreas = iaExtrairAreas(textosPorPagina.slice(0,3).map(x=>x.txt).join(' '));
    const BLOCO=2; const blocos=[];
    for(let i=0;i<textosPorPagina.length;i+=BLOCO) blocos.push(textosPorPagina.slice(i,i+BLOCO));

    const todosItens = [];
    for(let b=0;b<blocos.length;b++) {
      setP(`⚡ Bloco ${b+1}/${blocos.length}...`);
      const textoBloco = blocos[b].map(x=>`=== PRANCHA ${x.pag} ===\n${x.txt}`).join('\n\n').substring(0,18000);
      const ctx = b===0 ? textoBloco : (contextoAreas?'=== ÁREAS ===\n'+contextoAreas+'\n\n':'')+textoBloco;
      const prompt = `Você é especialista em construção civil. Extraia TODOS os MATERIAIS necessários para execução desta obra.
Retorne SOMENTE JSON: {"itens":[{"descricao":"especificação EXATA do material","unidade":"m²/ml/un/L","quantidade":0.00,"ambiente":"Ambiente ou Etapa"}]}
REGRAS: use áreas dos ambientes para calcular qtd; descrição EXATA do documento; NUNCA quantidade 0; não repita itens de blocos anteriores.`;
      try {
        const r=await fetch(GROQ_URL,{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+apiKey},body:JSON.stringify({model:modelo,messages:[{role:'system',content:prompt},{role:'user',content:'PROJETO:\n'+ctx}],temperature:0.05,max_tokens:6000})});
        const data=await r.json();
        const txt2=data.choices?.[0]?.message?.content||'';
        const m=txt2.match(/\{[\s\S]*\}/);
        if(m) { const p=JSON.parse(iaRepararJSON(m[0])); (p.itens||[]).forEach(it=>todosItens.push(it)); }
      } catch(e){ console.warn('bloco',b,e.message); }
      if(b<blocos.length-1) await new Promise(r=>setTimeout(r,800));
    }

    // Aplica tabela de LED
    const ledCorrigidos = iaCorrigirFitasLED(todosItens);
    const dedupados = iaSomarDuplicatas(iaDeduplicar(ledCorrigidos,'descricao'));

    setP('');
    if(st) st.innerHTML=`<div style="background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3);border-radius:10px;padding:12px;font-size:12px;color:var(--accent3)">✅ ${dedupados.length} material(ais) identificado(s)</div>`;
    window._levIATemp = dedupados;
    if(res) res.innerHTML=`
      <div style="max-height:200px;overflow-y:auto;border:1px solid var(--border);border-radius:8px;margin-top:8px">
        ${dedupados.slice(0,30).map(it=>`<div style="display:grid;grid-template-columns:1fr 60px 80px;font-size:11px;padding:6px 10px;border-bottom:1px solid rgba(37,42,56,.5)">
          <div style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${it.descricao||it.nome||''}</div>
          <div style="text-align:center;color:var(--text3)">${it.unidade||''}</div>
          <div style="text-align:right;font-family:'JetBrains Mono',monospace;color:${(parseFloat(it.quantidade)||0)>0?'var(--accent3)':'var(--accent4)'}">${(parseFloat(it.quantidade)||0).toLocaleString('pt-BR',{maximumFractionDigits:2})}</div>
        </div>`).join('')}
      </div>
      <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:10px">
        <button class="btn btn-ghost" onclick="fecharModal()">Cancelar</button>
        <button class="btn btn-success" onclick="levIAImportar()">✅ Importar ${dedupados.length} material(ais)</button>
      </div>`;
  } catch(e) {
    if(st) st.innerHTML=`<div style="color:var(--accent4);font-size:12px;padding:8px">❌ ${e.message}</div>`;
  }
}

function iaExtrairAreas(texto) {
  const areas={};
  const re=/([A-ZÁÉÍÓÚÃÕÇ][A-ZÁÉÍÓÚÃÕÇa-záéíóúãõêâôçàü\s\/]{2,35})\s+A=([\d,.]+)m²/g;
  let m;
  while((m=re.exec(texto))!==null){
    const nome=m[1].trim(),area=parseFloat(m[2].replace(',','.'));
    if(nome.length>2&&nome.length<40&&!nome.match(/^\d/)&&area>0){
      if(!areas[nome]||area>areas[nome])areas[nome]=area;
    }
  }
  if(!Object.keys(areas).length) return '';
  const total=Object.values(areas).reduce((s,v)=>s+v,0);
  return Object.entries(areas).filter(([k])=>!k.match(/Rodrigues|Kalume|Caio|ARQ/i))
    .map(([k,v])=>`${k}: ${v}m²`).join('\n')+`\nÁREA TOTAL: ${total.toFixed(2)}m²`;
}

function iaRepararJSON(str) {
  str=str.replace(/,\s*([}\]])/g,'$1');
  let o=0,a=0,s=false,e=false;
  for(let i=0;i<str.length;i++){
    const c=str[i];
    if(e){e=false;continue;} if(c==='\\'&&s){e=true;continue;}
    if(c==='"'&&!e){s=!s;continue;} if(s)continue;
    if(c==='{')o++; else if(c==='}')o--; else if(c==='[')a++; else if(c===']')a--;
  }
  if(s)str+='"'; while(a>0){str+=']';a--;} while(o>0){str+='}';o--;}
  return str.replace(/,\s*([}\]])/g,'$1');
}

function levIAImportar() {
  const itens = window._levIATemp||[];
  if(!itens.length) return;
  itens.forEach(it=>levMatDados().itens.push({id:uid(),descricao:it.descricao||it.nome||'',unidade:it.unidade||'un',quantidade:parseFloat(it.quantidade)||0,ambiente:it.etapa||it.ambiente||''}));
  agendarSync(); fecharModal(); mudarModo('levantamento');
  mostrarNotificacao(`✅ ${itens.length} material(ais) importado(s)!`,'success');
}

// ══════════════════════════════════════════════════════════════════
//  🛒 COTAÇÃO DE MATERIAIS — Mapa de cotação multi-fornecedor
// ══════════════════════════════════════════════════════════════════
function cotacaoDados() {
  if(!dados.cotacao) dados.cotacao = { fornecedores:[], itens:[] };
  return dados.cotacao;
}

function renderizarCotacao() {
  const cot = cotacaoDados();
  const forn = cot.fornecedores || [];
  const itens = cot.itens || [];

  return `
  <div class="page-header">
    <div>
      <div class="page-title">🛒 Mapa de Cotação</div>
      <div class="page-sub">Compare preços de fornecedores · ${itens.length} item(s) · ${forn.length} fornecedor(es)</div>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <button class="btn btn-ghost" onclick="cotAdicionarFornecedor()">+ Fornecedor</button>
      <button class="btn btn-ghost" onclick="mudarModo('levantamento')">← Levantamento</button>
      <button class="btn btn-primary" onclick="cotExportarMapaExcel()">📥 Exportar Mapa Excel</button>
    </div>
  </div>

  ${forn.length===0||itens.length===0?`
  <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:50px;text-align:center;color:var(--text3)">
    <div style="font-size:40px;margin-bottom:12px">🛒</div>
    <div style="font-weight:700;font-size:14px;margin-bottom:6px">Mapa de cotação vazio</div>
    <div style="font-size:12px;margin-bottom:16px">
      ${itens.length===0?'Selecione materiais no Levantamento e clique em "Enviar para Cotação"':'Adicione pelo menos um fornecedor para começar'}
    </div>
    <div style="display:flex;gap:8px;justify-content:center">
      <button class="btn btn-ghost" onclick="mudarModo('levantamento')">← Ir ao Levantamento</button>
      <button class="btn btn-primary" onclick="cotAdicionarFornecedor()">+ Adicionar Fornecedor</button>
    </div>
  </div>`:

  `<!-- Mapa de cotação -->
  <div style="overflow-x:auto">
    <table style="width:100%;border-collapse:collapse;background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);overflow:hidden;font-size:12px">
      <thead>
        <tr style="background:var(--surface2);border-bottom:1px solid var(--border)">
          <th style="padding:10px 12px;text-align:left;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text3);font-weight:500;min-width:280px">MATERIAL</th>
          <th style="padding:10px 12px;text-align:center;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text3);font-weight:500;width:55px">UND</th>
          <th style="padding:10px 12px;text-align:right;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text3);font-weight:500;width:80px">QTD</th>
          ${forn.map((f,fi)=>`
          <th style="padding:8px 12px;text-align:center;min-width:130px">
            <div style="display:flex;align-items:center;justify-content:center;gap:6px">
              <input class="tc-edit" value="${f.nome||''}" placeholder="Fornecedor ${fi+1}" style="font-size:11px;font-weight:600;text-align:center;color:var(--accent2)"
                onchange="cotacaoDados().fornecedores[${fi}].nome=this.value;agendarSync()">
              <button onclick="cotExcluirFornecedor(${fi})" style="background:none;border:none;color:var(--text3);cursor:pointer;font-size:12px;padding:0">✕</button>
            </div>
          </th>`).join('')}
          <th style="padding:10px 12px;text-align:center;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--accent3);font-weight:700;min-width:120px">MENOR PREÇO</th>
          <th style="padding:10px 12px;text-align:right;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--accent3);font-weight:700;min-width:110px">TOTAL</th>
        </tr>
      </thead>
      <tbody>
        ${itens.map((item,ii)=>{
          const precos = forn.map(f=>{
            const p = item.precos?.[f.id];
            return p>0?p:null;
          });
          const validos = precos.filter(p=>p!==null);
          const menorPreco = validos.length>0?Math.min(...validos):null;
          const total = menorPreco!==null?(item.quantidade||0)*menorPreco:null;
          return `
        <tr style="border-bottom:1px solid rgba(255,255,255,.04);transition:background .12s" onmouseover="this.style.background='rgba(255,255,255,.02)'" onmouseout="this.style.background=''">
          <td style="padding:8px 12px">
            <div style="font-weight:500">${item.descricao||''}</div>
            <div style="font-size:10px;color:var(--text3)">${item.ambiente||''}</div>
          </td>
          <td style="padding:8px 12px;text-align:center;color:var(--text3)">${item.unidade||''}</td>
          <td style="padding:8px 12px;text-align:right;font-family:'JetBrains Mono',monospace">${(item.quantidade||0).toLocaleString('pt-BR',{maximumFractionDigits:2})}</td>
