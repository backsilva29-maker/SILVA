function handleFotos(files) {
  _fotosBuffer=[];
  const prev=document.getElementById('previewArea');
  const meta=document.getElementById('metaArea');
  if(!files.length) return;
  prev.innerHTML='<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:8px"></div>';
  const grid=prev.querySelector('div');
  let loaded=0;
  Array.from(files).forEach(file=>{
    const reader=new FileReader();
    reader.onload=e=>{
      _fotosBuffer.push({src:e.target.result,name:file.name});
      const img=document.createElement('div');
      img.style.cssText='border-radius:6px;overflow:hidden;border:1px solid var(--border)';
      img.innerHTML=`<img src="${e.target.result}" style="width:100%;height:80px;object-fit:cover">`;
      grid.appendChild(img);
      if(++loaded===files.length) meta.style.display='block';
    };
    reader.readAsDataURL(file);
  });
}
function confirmarFotos() {
  if(!_fotosBuffer.length){mostrarNotificacao('Selecione ao menos uma foto.','error');return;}
  const amb=document.getElementById('fotoAmb').value;
  const data=fmtData(new Date());
  _fotosBuffer.forEach(f=>dados.fotos.push({id:uid(),url:f.src,ambiente:amb,data}));
  _fotosBuffer=[];
  agendarSync();fecharModal();renderizarAdmin();mostrarNotificacao('Foto(s) salva(s)!','success');
}
function verFoto(i){
  const f=dados.fotos[i];
  abrirModal(f.ambiente,`<img src="${f.url}" style="width:100%;border-radius:10px;margin-bottom:12px"><div style="font-size:11px;color:var(--text3);margin-bottom:12px">📅 ${f.data}</div><div style="display:flex;gap:8px;justify-content:flex-end"><button class="btn btn-danger" onclick="excluirFoto(${i});fecharModal()">🗑️ Excluir</button><button class="btn btn-ghost" onclick="fecharModal()">Fechar</button></div>`);
}
function excluirFoto(i){if(confirm('Excluir foto?')){dados.fotos.splice(i,1);agendarSync();renderizarAdmin();mostrarNotificacao('Excluída!','success');}}

