function processarPlanilhaQuantitativos(file) {
  if(!file) return;
  const prev = document.getElementById('quantPreview');
  if(prev) prev.innerHTML = '<div style="font-size:12px;color:var(--text3);padding:8px">Lendo arquivo...</div>';
  const reader = new FileReader();
  reader.onerror = () => mostrarNotificacao('Erro ao ler o arquivo.','error');
  reader.onload = e => {
    try {
      const wb = XLSX.read(e.target.result, {type:'array'});
      const ws = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSX.utils.sheet_to_json(ws, {header:1, defval:''});
      // Detecta linha de cabeçalho
      let startRow = 0;
      for(let i=0;i<Math.min(12,rows.length);i++){
        const r=rows[i].map(c=>(c||'').toString().toLowerCase());
        if(r.some(c=>c.includes('descri')||c.includes('servi')||c.includes('cod')||c.includes('item')||c.includes('und'))) {
          startRow=i+1; break;
        }
      }
      const importados = [];
      for(let i=startRow;i<rows.length;i++){
        const r=rows[i];
        const cod  = (r[0]||'').toString().trim();
        const desc = (r[1]||'').toString().trim();
        if(!cod && !desc) continue;
        importados.push({
          id: uid(),
          codigo:    cod,
          descricao: desc,
          unidade:   (r[2]||'').toString().trim()||'un',
          quantidade: parseFloat((r[3]||'0').toString().replace(',','.'))||0,
          etapa:     (r[4]||'').toString().trim(),
          precoUnit: parseFloat((r[5]||'0').toString().replace(',','.'))||0,
          fonte:     orcDados().refTabela||'Importado'
        });
      }
      // Guarda em variável global — evita passar JSON por atributo HTML
      window._quantImportTemp = importados;
      if(!prev) return;
      if(importados.length===0) {
        prev.innerHTML='<div style="background:rgba(244,63,94,.1);border:1px solid rgba(244,63,94,.3);border-radius:10px;padding:12px;font-size:12px;color:var(--accent4)">⚠️ Nenhum item encontrado. Verifique se o arquivo tem dados a partir da linha 1 ou 2.</div>';
        return;
      }
      prev.innerHTML = `
        <div style="background:var(--surface2);border-radius:10px;padding:12px;margin-bottom:10px">
          <div style="font-weight:600;margin-bottom:6px;color:var(--accent3)">✅ ${importados.length} item(ns) encontrado(s)</div>
          <div style="font-size:11px;color:var(--text3);margin-bottom:6px">Prévia:</div>
          <div style="overflow-x:auto">
            <div style="display:grid;grid-template-columns:100px 1fr 50px 70px 90px;gap:4px;font-size:10px;color:var(--text3);font-family:'JetBrains Mono',monospace;text-transform:uppercase;border-bottom:1px solid var(--border);padding-bottom:4px;margin-bottom:4px">
              <div>Código</div><div>Descrição</div><div>Und</div><div>Qtd</div><div>Preço</div>
            </div>
            ${importados.slice(0,5).map(x=>`
            <div style="display:grid;grid-template-columns:100px 1fr 50px 70px 90px;gap:4px;font-size:11px;padding:2px 0">
              <div style="font-family:'JetBrains Mono',monospace;color:var(--text3)">${x.codigo||'—'}</div>
              <div style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${x.descricao}</div>
              <div>${x.unidade}</div>
              <div>${x.quantidade}</div>
              <div style="font-family:'JetBrains Mono',monospace">${x.precoUnit>0?fmtR(x.precoUnit):'—'}</div>
            </div>`).join('')}
            ${importados.length>5?`<div style="font-size:10px;color:var(--text3);margin-top:4px">... e mais ${importados.length-5} item(ns)</div>`:''}
          </div>
        </div>
        <div style="display:flex;gap:8px;justify-content:flex-end">
          <button class="btn btn-ghost" onclick="fecharModal()">Cancelar</button>
          <button class="btn btn-primary" onclick="confirmarImportacaoQuant()">✅ Importar ${importados.length} item(ns)</button>
        </div>`;
    } catch(err) {
      if(prev) prev.innerHTML=`<div style="background:rgba(244,63,94,.1);border:1px solid rgba(244,63,94,.3);border-radius:10px;padding:12px;font-size:12px;color:var(--accent4)">❌ Erro ao ler: ${err.message}</div>`;
    }
  };
  reader.readAsArrayBuffer(file);
}

