function detectarAtrasos() {
  const semA = getSemanaAtual();
  const atrasos = [];
  (dados.grupos||[]).forEach((g,gi)=>{
    (g.tarefas||[]).forEach((t,ti)=>{
      const fimEsperado=(t.inicio||0)+(t.duracao||0);
      if(semA>fimEsperado&&(t.progresso||0)<100){
        atrasos.push({grupo:g.nome,tarefa:t.nome,gi,ti,diasAtraso:Math.round((semA-fimEsperado)*7),progresso:t.progresso||0,cor:g.cor});
      }
    });
  });
  return atrasos;
}
function detectarAvisos() {
  const semA = getSemanaAtual();
  const avisos = [];
  (dados.grupos||[]).forEach((g,gi)=>{
    (g.tarefas||[]).forEach((t,ti)=>{
      const fimEsperado=(t.inicio||0)+(t.duracao||0);
      if(semA>=fimEsperado-1&&semA<=fimEsperado&&(t.progresso||0)<100){
        avisos.push({grupo:g.nome,tarefa:t.nome,gi,ti,diasRestantes:Math.round((fimEsperado-semA)*7),progresso:t.progresso||0,cor:g.cor});
      }
    });
  });
  return avisos;
}
