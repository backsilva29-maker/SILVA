function bibCompLerServicos(file) {
  if(!file) return;
  const r = new FileReader();
  r.onload = e => {
    try {
      const wb = XLSX.read(e.target.result,{type:'binary'});
      const ws = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSX.utils.sheet_to_json(ws,{header:1,defval:''});
      // Detecta header
      let start=0;
      for(let i=0;i<Math.min(8,rows.length);i++){
        const r2=rows[i].map(c=>(c||'').toString().toLowerCase());
        if(r2.some(c=>c.includes('descri')||c.includes('servi')||c.includes('cod'))) { start=i+1; break; }
      }
      const servicos = [];
      for(let i=start;i<rows.length;i++){
        const row=rows[i];
        const cod=(row[0]||'').toString().trim();
        const desc=(row[1]||'').toString().trim();
        if(!cod&&!desc) continue;
        servicos.push({ codigo:cod, descricao:desc, unidade:(row[2]||'').toString().trim()||'un', insumos:[] });
      }
      window._bibServicosTemp = servicos;
      const st = document.getElementById('bibStServicos');
      if(st) st.innerHTML=`<span style="color:var(--accent3)">✅ ${servicos.length} serviço(s)</span>`;
      bibCompVerificarImport();
    } catch(err) { mostrarNotificacao('Erro ao ler planilha de serviços: '+err.message,'error'); }
  };
  r.readAsBinaryString(file);
}

function bibCompLerInsumos(file) {
  if(!file) return;
  const r = new FileReader();
  r.onload = e => {
    try {
      const wb = XLSX.read(e.target.result,{type:'binary'});
      const ws = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSX.utils.sheet_to_json(ws,{header:1,defval:''});
      let start=0;
      for(let i=0;i<Math.min(8,rows.length);i++){
        const r2=rows[i].map(c=>(c||'').toString().toLowerCase());
        if(r2.some(c=>c.includes('insumo')||c.includes('descri')||c.includes('coef')||c.includes('cod'))) { start=i+1; break; }
      }
      const insumos = [];
      for(let i=start;i<rows.length;i++){
        const row=rows[i];
        if(!row[0]&&!row[1]) continue;
        // tenta detectar colunas: codServico | codInsumo | descricao | und | coef | precoUnit
        insumos.push({
          codServico:  (row[0]||'').toString().trim(),
          codigo:      (row[1]||'').toString().trim(),
          descricao:   (row[2]||'').toString().trim(),
          unidade:     (row[3]||'').toString().trim()||'un',
          coef:        parseFloat((row[4]||'0').toString().replace(',','.'))||0,
          precoUnit:   parseFloat((row[5]||'0').toString().replace(',','.'))||0,
          precoAnterior: 0,
          fonte:       'TCPO'
        });
      }
      window._bibInsumosTemp = insumos;
      const st = document.getElementById('bibStInsumos');
      if(st) st.innerHTML=`<span style="color:var(--accent3)">✅ ${insumos.length} insumo(s)</span>`;
      bibCompVerificarImport();
    } catch(err) { mostrarNotificacao('Erro ao ler planilha de insumos: '+err.message,'error'); }
  };
  r.readAsBinaryString(file);
}

function bibCompVerificarImport() {
  const servicos = window._bibServicosTemp;
  const insumos  = window._bibInsumosTemp;
  const prev  = document.getElementById('bibImportPreview');
  const btn   = document.getElementById('bibConfirmBtn');
  if(!prev||!btn) return;

  if(servicos && insumos) {
    // Vincula insumos aos serviços pelo código
    servicos.forEach(s => {
      s.insumos = insumos.filter(ins => ins.codServico === s.codigo || (!s.codigo && ins.codServico === ''));
    });
    // Serviços sem código na planilha de insumos = vincula pelo índice (planilha única)
    const semVinculo = insumos.filter(ins => !servicos.some(s=>s.codigo===ins.codServico));
    prev.innerHTML=`<div style="background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.3);border-radius:10px;padding:12px;font-size:12px">
      ✅ <strong>${servicos.length}</strong> serviços · <strong>${insumos.length}</strong> insumos vinculados · <strong>${semVinculo.length}</strong> insumos sem vínculo
    </div>`;
    btn.style.display='';
  } else if(servicos && !insumos) {
    prev.innerHTML=`<div style="background:rgba(232,160,32,.08);border:1px solid rgba(232,160,32,.3);border-radius:10px;padding:10px;font-size:12px;color:var(--accent)">⚠️ Importe também a planilha de insumos, ou confirme importando só os serviços.</div>`;
    btn.style.display='';
  } else if(!servicos && insumos) {
    prev.innerHTML=`<div style="background:rgba(232,160,32,.08);border:1px solid rgba(232,160,32,.3);border-radius:10px;padding:10px;font-size:12px;color:var(--accent)">⚠️ Importe também a planilha de serviços.</div>`;
  }
}

function bibCompConfirmarImport() {
  const servicos = window._bibServicosTemp || [];
  const insumos  = window._bibInsumosTemp  || [];
  const bib = bibCompDados();

  if(servicos.length>0) {
    servicos.forEach(s => {
      const exist = bib.composicoes.findIndex(c=>c.codigo===s.codigo && s.codigo);
      if(exist>=0) {
        // Atualiza existente
        if(s.insumos.length>0) bib.composicoes[exist].insumos = s.insumos;
      } else {
        bib.composicoes.push({ id:uid(), ...s });
      }
    });
  } else if(insumos.length>0) {
    // Só insumos sem serviços: agrupa por codServico
    const grupos = {};
    insumos.forEach(ins => {
      const k = ins.codServico||'_sem_codigo';
      if(!grupos[k]) grupos[k] = [];
      grupos[k].push(ins);
    });
    Object.entries(grupos).forEach(([cod,ins])=>{
      bib.composicoes.push({ id:uid(), codigo:cod==='_sem_codigo'?'':cod, descricao:'Composição importada', unidade:'un', insumos:ins, fonte:'TCPO' });
    });
  }

  agendarSync();
  fecharModal();
  _bibCompSel = 0;
  mudarSubOrc('bibComp');
  mostrarNotificacao(`✅ ${servicos.length||Object.keys({}).length} composição(ões) importada(s)!`,'success');
}

// ── Atualizar preços de uma composição ──
async function bibCompAtualizarPrecos(idx) {
  const bib = bibCompDados();
  const comp = bib.composicoes[idx];
  if(!comp) return;
  let atualizados = 0;
  const msg = document.getElementById('bibCompMsg');
  if(msg) msg.innerHTML=`<div style="display:flex;align-items:center;gap:8px;font-size:12px;color:var(--text2)"><div style="width:14px;height:14px;border:2px solid var(--accent);border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite"></div> Buscando preços...</div>`;

  for(const ins of (comp.insumos||[])) {
    if(!ins.codigo) continue;
    const found = await bibCompBuscarPreco(ins.codigo);
    if(found && found.preco>0) {
      ins.precoAnterior = ins.precoUnit || 0;
      ins.precoUnit = found.preco;
      ins.fonte = found.fonte;
      atualizados++;
    }
  }
  agendarSync();
  mudarSubOrc('bibComp');
  if(msg) msg.innerHTML='';
  mostrarNotificacao(`🔄 ${atualizados} insumo(s) com preço atualizado!`, atualizados>0?'success':'error');
}

// ── Atualizar todos ──
async function bibCompAtualizarTodos() {
  const bib = bibCompDados();
  let total = 0;
  const msg = document.getElementById('bibCompMsg');
  if(msg) msg.innerHTML=`<div style="display:flex;align-items:center;gap:8px;font-size:12px;color:var(--text2)"><div style="width:14px;height:14px;border:2px solid var(--accent);border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite"></div> Atualizando todos os preços...</div>`;
  for(let ci=0;ci<bib.composicoes.length;ci++) {
    for(const ins of (bib.composicoes[ci].insumos||[])) {
      if(!ins.codigo) continue;
      const found = await bibCompBuscarPreco(ins.codigo);
      if(found && found.preco>0) { ins.precoAnterior=ins.precoUnit||0; ins.precoUnit=found.preco; ins.fonte=found.fonte; total++; }
    }
  }
  agendarSync(); mudarSubOrc('bibComp');
  if(msg) msg.innerHTML='';
  mostrarNotificacao(`🔄 ${total} insumo(s) atualizado(s) em todas as composições!`,'success');
}

