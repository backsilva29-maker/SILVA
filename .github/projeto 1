// Selecionar versão específica de uma tabela → sincroniza tudo no orçamento
function selecionarTabelaVersao(id, mesRef) {
  const itens = getTabelaExtraDados(id, mesRef);
  if(!itens.length) {
    mostrarNotificacao('Dados desta versão não encontrados. Reimporte o arquivo.', 'error');
    return;
  }
  // Sincronizar tabela ativa + mês de referência
  setTabelaAtiva(id, mesRef);
  // Se for SINAPI, atualizar tabelaImportada também
  if(id.startsWith('SINAPI')) {
    orcDados().tabelaImportada = itens;
    setSinapiMesRef(mesRef);
  }
  mostrarNotificacao(`✅ Usando ${id} — ${mesRef} (${itens.length} composições)`, 'success');
  mudarSubOrc('tabPrecos');
}

// Buscar dentro de uma versão específica
function pesquisarTabelaVersao(id, mesRef) {
  const itens = getTabelaExtraDados(id, mesRef);
  if(!itens.length) { mostrarNotificacao('Sem dados para esta versão.', 'error'); return; }
  abrirModal(`🔍 ${id} — ${mesRef} (${itens.length} itens)`, `
