function iaRepararJSON(str) {
  str=str.replace(/,\s*([}\]])/g,'$1');
  var o=0,a=0,s=false,e=false;
  for(var i=0;i<str.length;i++){
    var c=str[i];
    if(e){e=false;continue;} if(c==='\\'&&s){e=true;continue;}
    if(c==='"'&&!e){s=!s;continue;} if(s)continue;
    if(c==='{')o++; else if(c==='}')o--; else if(c==='[')a++; else if(c===']')a--;
  }
  if(s)str+='"'; while(a>0){str+=']';a--;} while(o>0){str+='}';o--;}
  return str.replace(/,\s*([}\]])/g,'$1');
}

function iaExtrairAreas(texto) {
  var areas={};
  var re=/([A-ZÁÉÍÓÚÃÕÇ][A-ZÁÉÍÓÚÃÕÇa-záéíóúãõêâôçàü\s\/]{2,35})\s+A=([\d,.]+)m²/g;
  var m;
  while((m=re.exec(texto))!==null){
    var nome=m[1].trim(),area=parseFloat(m[2].replace(',','.'));
    if(nome.length>2&&nome.length<40&&!nome.match(/^\d/)&&area>0){
      if(!areas[nome]||area>areas[nome])areas[nome]=area;
    }
  }
  if(!Object.keys(areas).length) return '';
  var total=Object.values(areas).reduce(function(s,v){return s+v;},0);
  return Object.entries(areas).filter(function(e){return !e[0].match(/Rodrigues|Kalume|Caio|ARQ/i);})
    .map(function(e){return e[0]+': '+e[1]+'m²';}).join('\n')+'\nÁREA TOTAL: '+total.toFixed(2)+'m²';
}

