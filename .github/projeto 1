    <button class="btn btn-success" onclick="cotGerarOrdemCompra()">📋 Gerar Ordem de Compra</button>
  </div>`}`;
}

function cotAdicionarFornecedor() {
  const nome = prompt('Nome do fornecedor:');
  if(!nome) return;
  cotacaoDados().fornecedores.push({ id:'forn_'+uid(), nome });
  agendarSync(); mudarModo('cotacao');
}
function cotExcluirFornecedor(fi) {
  if(!confirm('Remover fornecedor?')) return;
  const id = cotacaoDados().fornecedores[fi]?.id;
  cotacaoDados().fornecedores.splice(fi,1);
  if(id) cotacaoDados().itens.forEach(it=>{ if(it.precos) delete it.precos[id]; });
  agendarSync(); mudarModo('cotacao');
}
function cotSalvarPreco(ii, fornId, preco) {
  const item = cotacaoDados().itens[ii];
  if(!item) return;
  if(!item.precos) item.precos = {};
  item.precos[fornId] = preco;
  agendarSync(); mudarModo('cotacao');
}
function cotAdicionarItem() {
  const desc = prompt('Descrição do material:');
  if(!desc) return;
  cotacaoDados().itens.push({ id:uid(), descricao:desc, unidade:'un', quantidade:1, precos:{} });
  agendarSync(); mudarModo('cotacao');
}
function cotExportarMapaExcel() {
  const cot = cotacaoDados();
  const header = ['Material','Ambiente','Und','Qtd',...cot.fornecedores.map(f=>f.nome),'Menor Preço','Total'];
  const rows = cot.itens.map(it=>{
    const precos = cot.fornecedores.map(f=>it.precos?.[f.id]||'');
    const validos = precos.filter(p=>p>0);
    const menor = validos.length>0?Math.min(...validos):'';
    const total = menor?(it.quantidade||0)*menor:'';
    return [it.descricao||'',it.ambiente||'',it.unidade||'',it.quantidade||0,...precos,menor,total];
  });
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet([header,...rows]), 'Mapa Cotação');
  XLSX.writeFile(wb,`mapa_cotacao_${dados.titulo||'obra'}.xlsx`);
  mostrarNotificacao('Mapa exportado!','success');
}
function cotGerarOrdemCompra() {
  const cot = cotacaoDados();
  if(!cot.itens.length||!cot.fornecedores.length) { mostrarNotificacao('Nenhum dado para gerar ordem.','error'); return; }
  // Agrupa por fornecedor vencedor (menor preço)
  const porForn = {};
  cot.itens.forEach(it=>{
    const precos = cot.fornecedores.map(f=>({f,p:it.precos?.[f.id]||0})).filter(x=>x.p>0);
    if(!precos.length) return;
    const melhor = precos.reduce((a,b)=>a.p<=b.p?a:b);
    if(!porForn[melhor.f.id]) porForn[melhor.f.id]={nome:melhor.f.nome,itens:[]};
    porForn[melhor.f.id].itens.push({...it,precoUnit:melhor.p,total:(it.quantidade||0)*melhor.p});
  });
  const wb = XLSX.utils.book_new();
  Object.values(porForn).forEach(forn=>{
    const rows=[['Descrição','Und','Qtd','P.Unit','Total'],...forn.itens.map(i=>[i.descricao,i.unidade,i.quantidade,i.precoUnit,i.total])];
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(rows),forn.nome.substring(0,31));
  });
  XLSX.writeFile(wb,`ordem_compra_${dados.titulo||'obra'}.xlsx`);
  mostrarNotificacao('Ordem de compra gerada!','success');
}

