function iaOrcSwitchTab(tab) {
  ['texto','pdf','excel'].forEach(t => {
    const panel = document.getElementById('iaOrcPanel'+t.charAt(0).toUpperCase()+t.slice(1));
    const btn   = document.getElementById('iaOrcTab'+t.charAt(0).toUpperCase()+t.slice(1));
    if(panel) panel.style.display = t===tab ? '' : 'none';
    if(btn) { btn.className = t===tab ? 'btn btn-purple' : 'btn btn-ghost'; btn.style.justifyContent='center'; btn.style.fontSize='12px'; }
  });
}

async function iaOrcProcessarPDF(file) {
  if(!file || file.type!=='application/pdf') { mostrarNotificacao('Selecione um PDF válido.','error'); return; }
  const st  = document.getElementById('iaOrcPDFStatus');
  const key = getGroqKey();
  const modelo = document.getElementById('iaOrcModelSel')?.value || groqModel;
  if(!key) {
    if(st) st.innerHTML=`<div style="background:rgba(244,63,94,.1);border:1px solid rgba(244,63,94,.3);border-radius:10px;padding:12px;font-size:12px;color:var(--accent4)">❌ Configure a chave Groq no topo da página.</div>`;
    return;
  }
  if(st) st.innerHTML=`<div style="display:flex;align-items:center;gap:10px;background:var(--surface2);border-radius:10px;padding:14px">
    <div style="width:18px;height:18px;border:2px solid var(--accent5);border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite;flex-shrink:0"></div>
    <div id="iaOrcPDFProgress" style="font-size:12px;color:var(--text2)">📄 Carregando PDF...</div></div>`;
  const setP = msg => { const e=document.getElementById('iaOrcPDFProgress'); if(e) e.textContent=msg; };
  try {
    if(typeof pdfjsLib==='undefined') {
      await carregarScript('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js');
      pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    }
    const ab  = await file.arrayBuffer();
    const pdf = await pdfjsLib.getDocument({data:ab}).promise;
    const totalPags = pdf.numPages;
    const textosPorPagina = [];
    for(let p=1;p<=totalPags;p++) {
      setP(`📄 Extraindo página ${p}/${totalPags}...`);
      const pg=await pdf.getPage(p); const tc=await pg.getTextContent();
      const txt=tc.items.map(i=>i.str).join(' ').trim();
      if(txt.length>30) textosPorPagina.push({pag:p,txt:iaLimparTextoPDF(txt)});
    }
    if(textosPorPagina.length===0) throw new Error('Não foi possível extrair texto do PDF.');
    const BLOCO=2;
    const blocos=[];
    for(let i=0;i<textosPorPagina.length;i+=BLOCO) blocos.push(textosPorPagina.slice(i,i+BLOCO));
    const tabela = orcDados().refTabela||'SINAPI-PA';
    const todosItens=[];
    for(let b=0;b<blocos.length;b++) {
      const pags=blocos[b].map(x=>x.pag).join(',');
      setP(`⚡ Analisando bloco ${b+1}/${blocos.length} (pág. ${pags})...`);
      const textoBloco=blocos[b].map(x=>`=== PRANCHA ${x.pag} ===
${x.txt}`).join('\n\n').substring(0,18000);
      try {
        const ctxAreas = b===0 ? '' : (iaExtrairAreas(blocos[0].map(x=>x.txt).join(' ')) ? '=== ÁREAS DOS AMBIENTES ===\n'+iaExtrairAreas(blocos[0].map(x=>x.txt).join(' '))+'\n\n' : '');
        const r = await iaCallGroq(key, modelo, 'orcamento', ctxAreas+textoBloco, tabela);
        (r.itens||r.servicos||[]).forEach(it=>todosItens.push(it));
      } catch(e) { console.warn('Bloco '+b+' falhou:',e.message); }
      if(b<blocos.length-1) await new Promise(r=>setTimeout(r,800));
    }
    const result = { titulo: file.name, resumo: '', servicos: iaSomarDuplicatas(iaDeduplicar(todosItens,'descricao','nome')), composicoes:[], totalCD:0, observacoes:`Processado em ${blocos.length} bloco(s), ${totalPags} página(s)` };
    result.totalCD = (result.servicos||[]).reduce((s,i)=>s+(i.totalCD||0),0);
    iaOrcMostrarResultado(result, st);
  } catch(e) {
    if(st) st.innerHTML=`<div style="background:rgba(244,63,94,.1);border:1px solid rgba(244,63,94,.3);border-radius:10px;padding:12px;font-size:12px;color:var(--accent4)">❌ ${e.message}</div>`;
  }
}


async function iaOrcProcessarExcel(file) {
  if(!file) return;
  const st = document.getElementById('iaOrcXLSStatus');
  const key = getGroqKey();
  const modelo = document.getElementById('iaOrcModelSel')?.value || groqModel;
  if(!key) { st.innerHTML=`<div style="background:rgba(244,63,94,.1);border:1px solid rgba(244,63,94,.3);border-radius:10px;padding:12px;font-size:12px;color:var(--accent4)">❌ Configure a chave Groq no topo da página.</div>`; return; }
  st.innerHTML=`<div style="display:flex;align-items:center;gap:10px;background:var(--surface2);border-radius:10px;padding:14px"><div style="width:18px;height:18px;border:2px solid var(--accent5);border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite;flex-shrink:0"></div><div style="font-size:12px;color:var(--text2)">📊 Lendo planilha...</div></div>`;
  try {
    const ab = await file.arrayBuffer();
    const wb = XLSX.read(ab,{type:'array'});
    const ws = wb.Sheets[wb.SheetNames[0]];
    const rows = XLSX.utils.sheet_to_json(ws,{header:1,defval:''});
    // Converte para texto compacto para enviar à IA (máx 200 linhas)
    const linhas = rows.slice(0,200).map(r=>r.map(c=>(c||'').toString().trim()).filter(Boolean).join(' | ')).filter(Boolean);
    const textoTabela = linhas.join('\n').substring(0,10000);
    if(linhas.length<2) throw new Error('Planilha vazia ou sem dados legíveis.');
    st.innerHTML=`<div style="display:flex;align-items:center;gap:10px;background:var(--surface2);border-radius:10px;padding:14px"><div style="width:18px;height:18px;border:2px solid var(--accent5);border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite;flex-shrink:0"></div><div style="font-size:12px;color:var(--text2)">⚡ Interpretando planilha com Groq (${linhas.length} linhas)...</div></div>`;
    const tabela = orcDados().refTabela||'SINAPI-PA';
    const sysPrompt = `Você é um orçamentista especialista em construção civil brasileiro (padrão ${tabela}).
Analise a planilha e extraia todos os serviços/insumos com quantidades calculadas.
REGRAS OBRIGATÓRIAS:
- Se a planilha tiver áreas de ambientes, use-as para calcular quantidades de revestimento, pintura, forro
- Se já tiver quantidades preenchidas, use-as diretamente
- Se a quantidade estiver vazia ou zerada, calcule com base nas informações disponíveis na planilha
- NUNCA retorne quantidade 0 se houver dados suficientes para calcular
- Identifique e preencha o código SINAPI quando possível
- Agrupe por etapa: Demolição, Alvenaria, Revestimentos, Pisos, Forro/Gesso, Pintura, Elétrica, Hidráulica, Marcenaria, Outros
Retorne SOMENTE JSON válido, sem texto extra:
{"titulo":"Título","resumo":"Resumo","servicos":[{"item":"1","codigo":"cod SINAPI","nome":"Nome","unidade":"m²","quantidade":0.00,"precoUnit":0.00,"totalCD":0.00,"etapa":"Etapa"}],"composicoes":[],"totalCD":0.0,"observacoes":"Premissas de cálculo"}`;
    const resp = await fetch(GROQ_URL,{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+key},body:JSON.stringify({model:modelo,messages:[{role:'system',content:sysPrompt},{role:'user',content:'Planilha:\n'+textoTabela}],temperature:0.1,max_tokens:8000})});
    if(!resp.ok){const e=await resp.json().catch(()=>({}));throw new Error(e.error?.message||'HTTP '+resp.status);}
    const data=await resp.json();
    const txt=data.choices?.[0]?.message?.content||'';
    const match=txt.match(/\{[\s\S]*\}/);
    if(!match) throw new Error('IA não retornou JSON válido.');
    const result=JSON.parse(match[0]);
    iaOrcMostrarResultado(result, st);
  } catch(e) {
    st.innerHTML=`<div style="background:rgba(244,63,94,.1);border:1px solid rgba(244,63,94,.3);border-radius:10px;padding:12px;font-size:12px;color:var(--accent4)">❌ ${e.message}</div>`;
  }
}

