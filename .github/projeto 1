function levMatProcessarExcel(file) {
  if(!file) return;
  const prev = document.getElementById('levMatPreview');
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const wb = XLSX.read(e.target.result,{type:'array'});
      const rows = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]],{header:1,defval:''});
      let start=0;
      for(let i=0;i<Math.min(10,rows.length);i++){
        const r=rows[i].map(c=>(c||'').toString().toLowerCase());
        if(r.some(c=>c.includes('descri')||c.includes('material')||c.includes('item'))) { start=i+1; break; }
      }
      const importados = rows.slice(start).filter(r=>(r[0]||r[1])).map(r=>({
        id:uid(), descricao:(r[0]||r[1]||'').toString().trim(),
        ambiente:(r[1]||r[2]||'').toString().trim(), unidade:(r[2]||r[3]||'un').toString().trim(),
        quantidade:parseFloat((r[3]||r[4]||'0').toString().replace(',','.'))||0
      }));
      window._levImportTemp = importados;
      if(prev) prev.innerHTML=`<div style="background:var(--surface2);border-radius:8px;padding:12px;margin-bottom:10px">
        <div style="font-weight:600;color:var(--accent3);margin-bottom:6px">✅ ${importados.length} item(s)</div>
        ${importados.slice(0,3).map(x=>`<div style="font-size:11px;color:var(--text3)">${x.descricao} · ${x.quantidade} ${x.unidade}</div>`).join('')}
        ${importados.length>3?`<div style="font-size:10px;color:var(--text3)">... e mais ${importados.length-3}</div>`:''}
      </div>
      <div style="display:flex;gap:8px;justify-content:flex-end">
        <button class="btn btn-ghost" onclick="fecharModal()">Cancelar</button>
        <button class="btn btn-primary" onclick="levMatConfirmarImport()">✅ Importar ${importados.length}</button>
      </div>`;
    } catch(e) { if(prev) prev.innerHTML=`<div style="color:var(--accent4);font-size:12px">❌ ${e.message}</div>`; }
  };
  reader.readAsArrayBuffer(file);
}

function levMatConfirmarImport() {
  const itens = window._levImportTemp;
  if(!itens||!itens.length) return;
  levMatDados().itens = [...levMatDados().itens, ...itens];
  agendarSync(); fecharModal(); mudarModo('levantamento');
  mostrarNotificacao(`✅ ${itens.length} item(s) importado(s)!`,'success');
}

