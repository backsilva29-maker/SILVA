const ICONES_TIPO={'pdf':'📄','doc':'📝','docx':'📝','xls':'📊','xlsx':'📊','ppt':'📋','pptx':'📋','jpg':'🖼️','jpeg':'🖼️','png':'🖼️','webp':'🖼️','gif':'🖼️','mp4':'🎬','mov':'🎬','zip':'📦','rar':'📦','dwg':'📐','dxf':'📐','txt':'📃','csv':'📊'};
function iconeArquivo(nome){const ext=(nome.split('.').pop()||'').toLowerCase();return ICONES_TIPO[ext]||'📎';}
function fmtTamanho(bytes){if(!bytes)return'—';if(bytes<1024)return bytes+' B';if(bytes<1024*1024)return(bytes/1024).toFixed(1)+' KB';return(bytes/(1024*1024)).toFixed(1)+' MB';}
function autoCategoriaArquivo(nome) {
  const ext=(nome.split('.').pop()||'').toLowerCase();
  const n=nome.toLowerCase();
  if(['dwg','dxf','rvt','skp','ifc'].includes(ext)) return 'Plantas';
  if(['pdf'].includes(ext)){
    if(/contrat|proposta|aditiv|rescis/.test(n)) return 'Contratos';
    if(/orçam|orcam|planilha|sinapi|seop|sicro/.test(n)) return 'Orçamentos';
    if(/memori|especif|laudo|relat/.test(n)) return 'Memoriais';
    if(/plant|corte|facha|elevaç|detalh/.test(n)) return 'Plantas';
    return 'Contratos';
  }
  if(['xls','xlsx','csv'].includes(ext)){
    if(/sinapi|seop|sicro|preç|preco|orcam|orçam/.test(n)) return 'Orçamentos';
    return 'Orçamentos';
  }
  if(['doc','docx'].includes(ext)){
    if(/contrat|proposta/.test(n)) return 'Contratos';
    if(/memori|especif/.test(n)) return 'Memoriais';
    return 'Memoriais';
  }
  if(['jpg','jpeg','png','webp','gif'].includes(ext)) return 'Fotos de Referência';
  if(['mp4','mov','avi'].includes(ext)) return 'Relatórios';
  return 'Outros';
}
function isPDF(nome){ return (nome.split('.').pop()||'').toLowerCase()==='pdf'; }
function isImagem(nome){ return ['jpg','jpeg','png','webp','gif'].includes((nome.split('.').pop()||'').toLowerCase()); }
