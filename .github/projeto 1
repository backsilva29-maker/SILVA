function calcularTotalCustoDirecto(orc) {
  return (orc.composicoes||[]).reduce((s,i)=>s+(i.quantidade||0)*(i.precoUnit||0),0);
}

function buscarPrecoTabela() {
  const orc = orcDados();
  let atualizados=0;
  // 1) Busca em tabelaImportada local
  if(orc.tabelaImportada && orc.tabelaImportada.length>0) {
    orc.composicoes.forEach(item=>{
      if(!item.codigo) return;
      const enc = orc.tabelaImportada.find(t=>(t.codigo||'').toString().trim()===item.codigo.toString().trim());
      if(enc) { item.precoUnit=parseFloat(enc.preco)||0; item.fonte=orc.refTabela; atualizados++; }
    });
  }
  // 2) Busca no Supabase tabela_precos para itens ainda sem preço
  const semPreco = orc.composicoes.filter(it=>it.codigo && (!it.precoUnit || it.precoUnit===0));
  if(semPreco.length>0) {
    const codigos = semPreco.map(it=>it.codigo.toString().trim()).join(',');
    fetch(`${SUPABASE_URL}/rest/v1/tabela_precos?codigo=in.(${codigos})&select=codigo,preco_unit,fonte,desonerado`,{
      headers:{'apikey':SUPABASE_KEY,'Authorization':'Bearer '+SUPABASE_KEY}
    }).then(r=>r.json()).then(rows=>{
      if(!Array.isArray(rows)) return;
      rows.forEach(row=>{
        const item = orc.composicoes.find(it=>it.codigo.toString().trim()===row.codigo.toString().trim() && (!it.precoUnit||it.precoUnit===0));
        if(item){ item.precoUnit=parseFloat(row.preco_unit)||0; item.fonte=row.fonte||orc.refTabela; atualizados++; }
      });
      agendarSync();
      mudarSubOrc('composicoes');
      if(atualizados>0) mostrarNotificacao(`${atualizados} preço(s) atualizado(s)!`,'success');
    }).catch(()=>{});
  }
  if(atualizados>0){ agendarSync(); mudarSubOrc('composicoes'); mostrarNotificacao(`${atualizados} preço(s) atualizado(s)!`,'success'); }
  else if(semPreco.length===0) mostrarNotificacao('Todos os itens já têm preço.','success');
}

// Busca automática de preço ao alterar código de um item
async function buscarPrecoPorCodigo(idx, codigo) {
  if(!codigo || codigo.length < 3) return;
  const orc = orcDados();
  const item = orc.composicoes[idx];
  if(!item) return;
  // 1) tabelaImportada local
  if(orc.tabelaImportada && orc.tabelaImportada.length>0) {
    const enc = orc.tabelaImportada.find(t=>(t.codigo||'').toString().trim()===codigo.trim());
    if(enc) {
      item.precoUnit=parseFloat(enc.preco)||0; item.fonte=orc.refTabela;
      if(!item.descricao && enc.descricao) item.descricao=enc.descricao;
      if(!item.unidade && enc.unidade) item.unidade=enc.unidade;
      agendarSync(); mudarSubOrc('levantamento');
      mostrarNotificacao('💰 Preço encontrado na tabela local!','success'); return;
    }
  }
  // 2) Supabase tabela_precos
  try {
    const r = await fetch(`${SUPABASE_URL}/rest/v1/tabela_precos?codigo=eq.${encodeURIComponent(codigo.trim())}&limit=1`,{
      headers:{'apikey':SUPABASE_KEY,'Authorization':'Bearer '+SUPABASE_KEY}
    });
    const rows = await r.json();
    if(Array.isArray(rows) && rows.length>0) {
      const row = rows[0];
      item.precoUnit=parseFloat(row.preco_unit)||0; item.fonte=row.fonte||orc.refTabela;
      if(!item.descricao && row.descricao) item.descricao=row.descricao;
      if(!item.unidade && row.unidade) item.unidade=row.unidade;
      agendarSync(); mudarSubOrc('levantamento');
      mostrarNotificacao('💰 Preço encontrado no Supabase ('+row.fonte+')!','success');
    }
  } catch(e) {}
}

