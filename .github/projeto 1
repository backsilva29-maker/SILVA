//  📅 NOVA ABA — CRONOGRAMA FÍSICO-FINANCEIRO
// ══════════════════════════════════════════════════════════════════
function renderizarCronogFin(orc) {
  const servicos = (orc.servicos||[]).filter(s=>!s._grupo);
  const totalCD = servicos.reduce((s,sv)=>s+(sv.totalCD||0),0);
  const bdiND = calcularBDITotal(orc.bdi.nd);

  // Montar meses baseado na duração da obra
  const meses = [];
  const di = getDataInicio();
  const dur = dados.duracaoTotal || 12;
  const nMeses = Math.max(Math.ceil(dur * 7 / 30), 3);
  for(let m=0; m<nMeses; m++) {
    const d = new Date(di.getFullYear(), di.getMonth()+m, 1);
    meses.push(d.toLocaleDateString('pt-BR',{month:'short',year:'2-digit'}));
  }

  // Distribui os grupos do Gantt no cronograma
  const grupos = dados.grupos || [];

  return `
  <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:16px;margin-bottom:6px">📅 Cronograma Físico-Financeiro</div>
  <div style="font-size:11px;color:var(--text2);margin-bottom:16px">
    Baseado nos grupos do Gantt e na planilha sintética. Exportação disponível em Excel e PDF.
  </div>
  <div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap">
    <div style="background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:10px 14px;font-size:12px">
      Custo direto total: <strong style="color:var(--accent3)">${fmtR(totalCD)}</strong>
    </div>
    <div style="background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:10px 14px;font-size:12px">
      Total c/ BDI (ND): <strong style="color:var(--accent)">${fmtR(totalCD*(1+bdiND/100))}</strong>
    </div>
    <div style="margin-left:auto;display:flex;gap:8px">
      <button class="btn btn-ghost" onclick="exportarCronograma()">📥 Excel</button>
      <button class="btn btn-ghost" onclick="exportarOrcamentoPDF()">📄 PDF</button>
    </div>
  </div>
  <div style="overflow-x:auto">
    <table style="width:100%;border-collapse:collapse;font-size:11px;min-width:600px">
      <thead>
        <tr style="background:var(--surface2)">
          <th style="text-align:left;padding:8px 10px;border:1px solid var(--border);min-width:180px">Etapa / Grupo</th>
          <th style="text-align:right;padding:8px 10px;border:1px solid var(--border);min-width:90px">Valor (R$)</th>
          ${meses.map(m=>`<th style="text-align:center;padding:8px 6px;border:1px solid var(--border);min-width:60px;font-family:'IBM Plex Mono',monospace;font-size:9px">${m}</th>`).join('')}
        </tr>
      </thead>
      <tbody>
        ${grupos.length===0?`<tr><td colspan="${2+meses.length}" style="padding:32px;text-align:center;color:var(--text3)">Adicione grupos no Cronograma para visualizar aqui</td></tr>`:''}
        ${grupos.map((g,gi)=>{
          const pgPct = calcularProgressoGrupo(g);
          // Duração do grupo em semanas → converter para meses
          const inicioMes = Math.floor(g.inicio*7/30);
          const fimMes = Math.min(Math.floor((g.inicio+g.duracao)*7/30), meses.length-1);
          const nMesesG = Math.max(fimMes - inicioMes + 1, 1);
          const valorG = totalCD > 0 ? (totalCD / grupos.length) : 0;
          const valorMes = valorG / nMesesG;
          return `
          <tr style="border-bottom:1px solid var(--border)">
            <td style="padding:8px 10px;border:1px solid var(--border)">
              <div style="display:flex;align-items:center;gap:6px">
                <div style="width:8px;height:8px;border-radius:50%;background:${g.cor};flex-shrink:0"></div>
                ${g.nome}
                <span style="font-size:10px;color:var(--accent2);margin-left:auto">${pgPct}%</span>
              </div>
            </td>
            <td style="padding:8px 10px;border:1px solid var(--border);text-align:right;font-family:'IBM Plex Mono',monospace;color:var(--accent3)">${fmtR(valorG)}</td>
            ${meses.map((_,mi)=>{
              if(mi >= inicioMes && mi <= fimMes) {
                const pctMes = Math.round(100/nMesesG);
                return `<td style="padding:6px;border:1px solid var(--border);text-align:center;background:rgba(59,130,246,.08);color:var(--accent2);font-weight:600;font-size:10px">${pctMes}%</td>`;
              }
              return `<td style="padding:6px;border:1px solid var(--border)"></td>`;
            }).join('')}
          </tr>`;
        }).join('')}
        <tr style="background:rgba(16,185,129,.06);font-weight:700">
          <td style="padding:8px 10px;border:1px solid var(--border)">TOTAL MENSAL (R$)</td>
          <td style="padding:8px 10px;border:1px solid var(--border);text-align:right;color:var(--accent3);font-family:'IBM Plex Mono',monospace">${fmtR(totalCD)}</td>
          ${meses.map((_,mi)=>{
            const pcts = (dados.grupos||[]).map(g=>{
              const im=Math.floor(g.inicio*7/30), fm=Math.min(Math.floor((g.inicio+g.duracao)*7/30),meses.length-1);
              const nM=Math.max(fm-im+1,1);
              return (mi>=im&&mi<=fm) ? (totalCD/Math.max((dados.grupos||[]).length,1))/nM : 0;
            });
            const tot = pcts.reduce((a,b)=>a+b,0);
            return `<td style="padding:6px;border:1px solid var(--border);text-align:center;font-family:'IBM Plex Mono',monospace;font-size:9px;color:${tot>0?'var(--accent)':'var(--text3)'}">${tot>0?'R$'+(tot/1000).toFixed(0)+'k':''}</td>`;
          }).join('')}
        </tr>
      </tbody>
    </table>
  </div>`;
}

