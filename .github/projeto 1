function getSinapiKey() { return localStorage.getItem('sinapi_api_key')||''; }
function setSinapiKey(k) { localStorage.setItem('sinapi_api_key', k); }
function getSinapiEstado() { return localStorage.getItem('sinapi_estado')||'PA'; }
function setSinapiEstado(v) { localStorage.setItem('sinapi_estado', v); }
function getSinapiUltimaAt() { return localStorage.getItem('sinapi_ultima_atualizacao')||''; }
function setSinapiUltimaAt(v) { localStorage.setItem('sinapi_ultima_atualizacao', v); }
function getSinapiMesRef() { return localStorage.getItem('sinapi_mes_ref')||''; }
function setSinapiMesRef(v) { localStorage.setItem('sinapi_mes_ref', v); }

const SINAPI_ESTADOS = ['AC','AL','AM','AP','BA','CE','DF','ES','GO','MA','MG','MS','MT','PA','PB','PE','PI','PR','RJ','RN','RO','RR','RS','SC','SE','SP','TO','BR'];

function sinapiPrecisaAtualizar() {
  const ultima = getSinapiUltimaAt();
  if(!ultima) return true;
  const d = new Date(ultima);
  const hoje = new Date();
  return (d.getMonth()!==hoje.getMonth()||d.getFullYear()!==hoje.getFullYear())&&hoje.getDate()>=12;
}

async function sinapiVerificarAtualizacaoAutomatica() {
  if(!getSinapiKey()) return;
  if(!sinapiPrecisaAtualizar()) return;
  const mesAtual = new Date().toLocaleDateString('pt-BR',{month:'2-digit',year:'numeric'});
  mostrarNotificacao(`🔄 SINAPI: nova tabela disponível (${mesAtual}). Acesse Orçamento → SINAPI para atualizar.`,'syncing');
}

async function sinapiAtualizarTabelaCompleta() {
  const key = getSinapiKey();
  const estado = getSinapiEstado();
  if(!key){mostrarNotificacao('Configure a chave API SINAPI primeiro.','error');return;}
  const btn = document.getElementById('btnAtualizarTabela');
  if(btn){btn.disabled=true;btn.textContent='⏳ Baixando...';}
  mostrarNotificacao('🔄 Baixando tabela SINAPI completa...','syncing');
  try {
    let todos=[],pagina=1,total=999;
    while(todos.length<total&&pagina<=20){
      const r=await fetch(`https://orcamentador.com.br/api/composicoes/?estado=${estado.toLowerCase()}&page=${pagina}&limit=100&regime=todos`,{headers:{'X-API-Key':key}});
      if(!r.ok) throw new Error('HTTP '+r.status);
      const d=await r.json();
      const itens=Array.isArray(d)?d:(d.results||d.data||d.itens||[]);
      total=d.total||d.count||itens.length;
      if(!itens.length) break;
      itens.forEach(it=>todos.push({
        codigo:it.codigo||it.code||'',descricao:it.descricao||it.description||'',
        unidade:it.unidade||it.unit||'un',
        preco:it.preco_naodesonerado||it.preco||it.custo_total||0,
        precoD:it.preco_desonerado||0
      }));
      pagina++;
      if(btn) btn.textContent=`⏳ Baixando... ${todos.length} itens`;
      await new Promise(r=>setTimeout(r,300));
    }
    if(!todos.length) throw new Error('Nenhum item retornado pela API.');
    orcDados().tabelaImportada=todos;
    orcDados().refTabela='SINAPI-'+estado;
    const mesRef=new Date().toLocaleDateString('pt-BR',{month:'2-digit',year:'numeric'});
    orcDados().refMes=mesRef;
    setSinapiUltimaAt(new Date().toISOString());
    setSinapiMesRef(mesRef);
    // Salvar histório de preços para comparação
    todos.forEach(it=>{ if(it.preco>0) sinapiSalvarHistorico(it.codigo,it.descricao,it.preco,mesRef); });
    agendarSync();
    mostrarNotificacao(`✅ SINAPI-${estado} atualizado! ${todos.length} itens · ${mesRef}`,'success');
    mudarSubOrc('tabPrecos');
  } catch(e){
    mostrarNotificacao('❌ Erro: '+e.message,'error');
  } finally {
    if(btn){btn.disabled=false;btn.textContent='🔄 Atualizar Tabela Completa';}
  }
}

function sinapiSalvarHistorico(codigo,descricao,preco,mes) {
  try {
    const hist=JSON.parse(localStorage.getItem('sinapi_historico')||'{}');
    if(!hist[codigo]) hist[codigo]={descricao,precos:[]};
    // Não duplicar mesmo mês
    if(!hist[codigo].precos.find(p=>p.mes===mes)) hist[codigo].precos.push({mes,preco,data:new Date().toISOString()});
    if(hist[codigo].precos.length>24) hist[codigo].precos.shift();
    localStorage.setItem('sinapi_historico',JSON.stringify(hist));
  } catch(e){}
}
function sinapiGetHistorico(codigo) {
  try { return JSON.parse(localStorage.getItem('sinapi_historico')||'{}')?.[codigo]?.precos||[]; }
  catch(e){return [];}
}

