async function iaLeituraProcessar(file) {
  if(!file) return;
  const st  = document.getElementById('pdfIASt');
  const res = document.getElementById('pdfIARes');
  const apiKey = (document.getElementById('pdfIAKey')?.value || getGroqKey()).trim();
  const modelo = document.getElementById('pdfGroqModel')?.value || groqModel;
  const modo   = document.querySelector('input[name="iaLeituraMode"]:checked')?.value || 'levantamento';
  groqModel = modelo;

  if(!apiKey) {
    if(st) st.innerHTML=`<div style="background:rgba(244,63,94,.1);border:1px solid rgba(244,63,94,.3);border-radius:10px;padding:12px;font-size:12px;color:var(--accent4)">❌ Configure a chave Groq acima.</div>`;
    return;
  }

  const isPDF = file.type==='application/pdf' || file.name.toLowerCase().endsWith('.pdf');

  // ── Excel/CSV: fluxo simples (não precisa de chunks) ──
  if(!isPDF) {
    if(st) st.innerHTML=`<div style="display:flex;align-items:center;gap:10px;background:var(--surface2);border-radius:10px;padding:14px">
      <div style="width:18px;height:18px;border:2px solid var(--accent5);border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite;flex-shrink:0"></div>
      <div style="font-size:12px;color:var(--text2)">📊 Lendo planilha...</div></div>`;
    try {
      const ab = await file.arrayBuffer();
      const wb = XLSX.read(ab,{type:'array'});
      const ws = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSX.utils.sheet_to_json(ws,{header:1,defval:''});
      const texto = rows.slice(0,300).map(r=>r.map(c=>(c||'').toString().trim()).filter(Boolean).join(' | ')).filter(Boolean).join('\n').substring(0,20000);
      if(texto.length<30) throw new Error('Planilha vazia ou sem dados legíveis.');
      if(st) st.innerHTML=`<div style="display:flex;align-items:center;gap:10px;background:var(--surface2);border-radius:10px;padding:14px">
        <div style="width:18px;height:18px;border:2px solid var(--accent5);border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite;flex-shrink:0"></div>
        <div style="font-size:12px;color:var(--text2)">⚡ Analisando com ${modelo}...</div></div>`;
      const result = await iaCallGroq(apiKey, modelo, modo, texto, orcDados().refTabela||'SINAPI-PA');
      iaLeituraMostrarResultado(result, st, res);
    } catch(e) {
      if(st) st.innerHTML=`<div style="background:rgba(244,63,94,.1);border:1px solid rgba(244,63,94,.3);border-radius:10px;padding:12px;font-size:12px;color:var(--accent4)">❌ ${e.message}</div>`;
    }
    return;
  }

  // ── PDF: extrai todas as páginas e processa em blocos ──
  if(st) st.innerHTML=`<div style="display:flex;align-items:center;gap:10px;background:var(--surface2);border-radius:10px;padding:14px">
    <div style="width:18px;height:18px;border:2px solid var(--accent5);border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite;flex-shrink:0"></div>
    <div id="iaProgressTxt" style="font-size:12px;color:var(--text2)">📄 Carregando PDF...</div></div>`;

  try {
    if(typeof pdfjsLib==='undefined') {
      await carregarScript('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js');
      pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    }
    const ab = await file.arrayBuffer();
    const pdf = await pdfjsLib.getDocument({data:ab}).promise;
    const totalPags = pdf.numPages;

    // Extrai texto de todas as páginas
    const textosPorPagina = [];
    for(let p=1;p<=totalPags;p++) {
      iaSetProgress(`📄 Extraindo página ${p}/${totalPags}...`);
      const pg  = await pdf.getPage(p);
      const tc  = await pg.getTextContent();
      const txt = tc.items.map(i=>i.str).join(' ').trim();
      if(txt.length > 30) textosPorPagina.push({ pag:p, txt: iaLimparTextoPDF(txt) });
    }

    if(textosPorPagina.length===0) throw new Error('Não foi possível extrair texto. O PDF pode ser uma imagem escaneada.');

    // Extrai áreas dos ambientes das primeiras páginas para contexto global
    const contextoAreas = iaExtrairAreas(textosPorPagina.slice(0,3).map(x=>x.txt).join(' '));

    // Define blocos de 3 páginas (equilibra contexto vs cobertura)
    const BLOCO = 2;
    const blocos = [];
    for(let i=0;i<textosPorPagina.length;i+=BLOCO) {
      blocos.push(textosPorPagina.slice(i,i+BLOCO));
    }

    const tabela = orcDados().refTabela||'SINAPI-PA';
    const todosItens = [];
    const todasComps = [];

    for(let b=0;b<blocos.length;b++) {
      const bloco = blocos[b];
      const pags  = bloco.map(x=>x.pag).join(',');
      iaSetProgress(`⚡ Analisando bloco ${b+1}/${blocos.length} (pág. ${pags}) com ${modelo}...`);
      const textoBloco = bloco.map(x=>`=== PRANCHA ${x.pag} ===\n${x.txt}`).join('\n\n').substring(0,18000);
      try {
        const textoComContexto = b===0 ? textoBloco : (contextoAreas ? '=== ÁREAS DOS AMBIENTES (use para calcular quantidades) ===\n'+contextoAreas+'\n\n' : '') + textoBloco;
        const result = await iaCallGroq(apiKey, modelo, modo, textoComContexto, tabela, b===0);
        if(modo==='composicoes') {
          (result.composicoes||[]).forEach(c=>todasComps.push(c));
        } else {
          (result.itens||result.servicos||[]).forEach(it=>todosItens.push(it));
        }
      } catch(e) {
        console.warn(`Bloco ${b+1} falhou:`, e.message);
      }
      // Pequena pausa entre chamadas para evitar rate limit
      if(b < blocos.length-1) await new Promise(r=>setTimeout(r,800));
    }

    // Consolida: remove duplicatas por descrição similar
    const consolidados = modo==='composicoes'
      ? iaDeduplicar(todasComps, 'descricao')
      : iaDeduplicar(todosItens, 'descricao', 'nome');

    // Soma quantidades de itens duplicados (mesmo serviço em pranchas diferentes)
    const somados = iaSomarDuplicatas(consolidados);

    iaSetProgress('');
    window._iaLeituraTemp = modo==='composicoes'
      ? { modo, comps: somados }
      : { modo, itens: somados };

    if(st) st.innerHTML=`<div style="background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3);border-radius:10px;padding:12px;font-size:12px;color:var(--accent3)">
      ✅ <strong>${somados.length}</strong> ${modo==='composicoes'?'composição(ões)':'item(ns)'} identificado(s) em <strong>${blocos.length}</strong> bloco(s) de ${totalPags} página(s)</div>`;
    iaLeituraMostrarLista(somados, modo, res);

  } catch(e) {
    if(st) st.innerHTML=`<div style="background:rgba(244,63,94,.1);border:1px solid rgba(244,63,94,.3);border-radius:10px;padding:12px;font-size:12px;color:var(--accent4)">❌ ${e.message}</div>`;
  }
}

