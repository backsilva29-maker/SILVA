function filtrarTabVersao(id, mesRef, q) {
  const itens = getTabelaExtraDados(id, mesRef);
  const ql = (q||'').toLowerCase();
  const filtrado = ql ? itens.filter(t =>
    (t.codigo||'').toLowerCase().includes(ql) ||
    (t.descricao||'').toLowerCase().includes(ql)
  ) : itens;
  const el = document.getElementById('resTabVersao');
  if(el) el.innerHTML = renderizarItensVersao(filtrado.slice(0,50), id, mesRef);
}


// ── FUNÇÕES DE SUPORTE PARA MÚLTIPLAS TABELAS ────────────────────
// ══════════════════════════════════════════════════════════════════
//  SISTEMA DE VERSIONAMENTO DE TABELAS
//  Cada tabela é identificada por ID + mês de referência
//  Permite manter múltiplas versões (Jan/2026, Out/2025, etc.)
//  para usar em licitações de períodos diferentes
// ══════════════════════════════════════════════════════════════════

// Chave única: "SEOP-PA__10/2025" (tabela + mês)
function chaveTabela(id, mesRef) {
  return (id + '__' + (mesRef||'')).replace(/[^a-zA-Z0-9_]/g, '_');
}

// Listar todas as versões salvas
function getTabelasSalvas() {
  try { return JSON.parse(localStorage.getItem('tabelas_versoes')||'[]'); }
  catch(e) { return []; }
}

// Versões de um ID específico, ordenadas do mais recente ao mais antigo
function getVersoesTabela(id) {
  return getTabelasSalvas()
    .filter(v => v.id === id)
    .sort((a,b) => {
      // Ordenar por mês de referência decrescente
      const [ma,aa] = (a.mesRef||'01/1900').split('/').map(Number);
      const [mb,ab] = (b.mesRef||'01/1900').split('/').map(Number);
      return (ab*12+mb) - (aa*12+ma);
    });
}

// Salvar uma versão (mantém versões anteriores!)
function salvarTabelaExtra(id, nome, itens, mesRef) {
  const mr = mesRef || new Date().toLocaleDateString('pt-BR',{month:'2-digit',year:'numeric'});
  const chave = chaveTabela(id, mr);
  const lista = getTabelasSalvas().filter(v => !(v.id===id && v.mesRef===mr));
  lista.push({
    id, nome, mesRef: mr, chave,
    itens: itens.length,
    dataImport: new Date().toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}),
    preview: itens.slice(0,3).map(i=>({codigo:i.codigo,descricao:(i.descricao||'').substring(0,50),preco:i.preco}))
  });
  localStorage.setItem('tabelas_versoes', JSON.stringify(lista));
  localStorage.setItem('tdados_'+chave, JSON.stringify(itens));
  console.log('Tabela salva:', id, mr, itens.length, 'itens');
}

// Obter dados de uma versão específica
function getTabelaExtraDados(id, mesRef) {
  // Se não passou mesRef, pegar a mais recente
  if(!mesRef) {
    const versoes = getVersoesTabela(id);
    if(!versoes.length) return [];
    mesRef = versoes[0].mesRef;
  }
  try {
    const chave = chaveTabela(id, mesRef);
    return JSON.parse(localStorage.getItem('tdados_'+chave)||'[]');
  } catch(e) { return []; }
}

// Excluir versão específica
function excluirTabelaExtra(id, mesRef) {
  const lista = getTabelasSalvas().filter(v => !(v.id===id && v.mesRef===mesRef));
  localStorage.setItem('tabelas_versoes', JSON.stringify(lista));
  if(mesRef) localStorage.removeItem('tdados_'+chaveTabela(id,mesRef));
  mostrarNotificacao('Versão removida!','success');
}

// Ao trocar tabela+mês no orçamento → sincroniza refMes automaticamente
function setTabelaAtiva(id, mesRef) {
  localStorage.setItem('tabela_ativa_id', id);
  orcDados().refTabela = id;
  // Se passou mesRef explícito, usar ele; senão pegar a versão mais recente disponível
  const mr = mesRef || (()=>{
    const v = getVersoesTabela(id);
    return v.length ? v[0].mesRef : (getSinapiMesRef()||'');
  })();
  if(mr) { orcDados().refMes = mr; }
  agendarSync();
}

function importarTabelaEspecifica(id, nome) {
  const inputId = 'fileTab_'+id.replace(/[^a-zA-Z0-9]/g,'_');
  const el = document.getElementById(inputId);
  if(el) el.click();
  else {
    // Criar input dinamicamente
    const inp = document.createElement('input');
    inp.type='file'; inp.accept='.xlsx,.xls,.csv'; inp.style.display='none';
    inp.onchange = e => { if(e.target.files[0]) processarTabelaEspecifica(e.target.files[0], id, nome); };
    document.body.appendChild(inp);
    inp.click();
  }
}

function receberDropTabela(e, id, nome) {
  e.preventDefault();
  if(e.dataTransfer.files[0]) processarTabelaEspecifica(e.dataTransfer.files[0], id, nome);
}

// ══════════════════════════════════════════════════════════════════
//  IMPORTADOR INTELIGENTE — detecta formato automaticamente
//  Suporta: SINAPI PDF, SEOP PDF, Excel/CSV genérico
// ══════════════════════════════════════════════════════════════════
async function processarTabelaEspecifica(file, id, nome) {
  if(!file) return;
  const ext = file.name.split('.').pop().toLowerCase();
  mostrarNotificacao(`🔄 Detectando formato de ${file.name}...`, 'syncing');

  try {
    if(ext === 'pdf') {
      await processarTabelaPDF(file, id, nome);
    } else {
      await processarTabelaExcel(file, id, nome);
    }
  } catch(err) {
    mostrarNotificacao('❌ Erro ao processar: '+err.message, 'error');
  }
}


// ── PROCESSADOR PDF — detecta SINAPI, SEOP e outros ──────────────
async function processarTabelaPDF(file, id, nome) {
  if(typeof pdfjsLib === 'undefined') {
    await carregarScript('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js');
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
  }

  const arrayBuffer = await file.arrayBuffer();
  const pdfDoc = await pdfjsLib.getDocument({data: arrayBuffer}).promise;
  const totalPags = pdfDoc.numPages;
  mostrarNotificacao(`📄 Lendo PDF ${nome} (${totalPags} páginas)...`, 'syncing');

  // Extrair palavras COM posição de todas as páginas
  const paginas = [];
  const maxPags = Math.min(totalPags, 250);
  for(let p = 1; p <= maxPags; p++) {
    const page = await pdfDoc.getPage(p);
    const tc   = await page.getTextContent();
    paginas.push(tc.items.map(i => ({str: i.str, x: i.transform[4], y: i.transform[5]})));
  }

  // Detectar formato pela página 1
  const pag1 = pdfLinhas(paginas[0]).join(' ');
  let itens = [], formato = 'PDF-genérico', mesRef = '';

  // Extrair mês/ano de referência do texto da página 1
  const mMes = pag1.match(/(?:MÊS|MES|REFERÊNCIA|REFERENCIA|OUTUBRO|NOVEMBRO|DEZEMBRO|JANEIRO|FEVEREIRO|MARÇO|ABRIL|MAIO|JUNHO|JULHO|AGOSTO|SETEMBRO)[^\d]*(\d{2}\/\d{4}|\d{4}\/\d{2}|(?:JAN|FEV|MAR|ABR|MAI|JUN|JUL|AGO|SET|OUT|NOV|DEZ)[^\d]*\d{4})/i);
  if(mMes) mesRef = mMes[1] || mMes[0].replace(/.*?(\d{2}\/\d{4})/,'$1');
  // Tentar pegar "OUTUBRO 2025" etc
  const mMesNome = pag1.match(/(JANEIRO|FEVEREIRO|MARÇO|ABRIL|MAIO|JUNHO|JULHO|AGOSTO|SETEMBRO|OUTUBRO|NOVEMBRO|DEZEMBRO)\s+(\d{4})/i);
  if(mMesNome && !mesRef) {
    const meses = {JANEIRO:'01',FEVEREIRO:'02','MARÇO':'03',ABRIL:'04',MAIO:'05',JUNHO:'06',JULHO:'07',AGOSTO:'08',SETEMBRO:'09',OUTUBRO:'10',NOVEMBRO:'11',DEZEMBRO:'12'};
    mesRef = (meses[mMesNome[1].toUpperCase()]||'??')+'/'+mMesNome[2];
  }
  // SINAPI: "Mês de Referência: 12/2025"
  const mSinapiMes = pag1.match(/[Mm][eê]s de Refer[eê]ncia[:\s]+(\d{2}\/\d{4})/);
  if(mSinapiMes) mesRef = mSinapiMes[1];

  if(pag1.includes('SINAPI') && (pag1.includes('RELATÓRIO DE CUSTOS') || pag1.includes('CUSTOS DE COMPOSIÇÕES'))) {
    formato = 'SINAPI-PDF'; itens = parsearSINAPI_PDF(paginas);
  } else if(pag1.includes('SEOP') || pag1.includes('SECRETARIA DE ESTADO DE OBRAS')) {
    formato = 'SEOP-PDF'; itens = parsearSEOP_PDF(paginas);
  } else if(pag1.includes('SEDOP')) {
    formato = 'SEDOP-PDF'; itens = parsearSEOP_PDF(paginas); // mesmo formato
  } else if(pag1.includes('ORSE') || pag1.includes('CEHOP')) {
    formato = 'ORSE-PDF'; itens = parsearGenericoPDF(paginas, 'ORSE');
  } else if(pag1.includes('SICRO') || pag1.includes('DNIT')) {
    formato = 'SICRO-PDF'; itens = parsearGenericoPDF(paginas, 'SICRO');
  } else {
    itens = parsearGenericoPDF(paginas, id);
  }

  if(!itens.length) {
    mostrarNotificacao(`❌ Nenhum item encontrado no PDF (${formato}). Verifique se o PDF tem texto selecionável.`, 'error');
    return;
  }
  finalizarImportacao(itens, id, nome, formato, mesRef);
}

// Reconstruir linhas de uma página pelo eixo Y (PDF.js)
function pdfLinhas(items) {
  const grupos = {};
  for(const it of items) {
    const y = Math.round(it.y / 5) * 5;
    if(!grupos[y]) grupos[y] = [];
    grupos[y].push({x: it.x, str: it.str});
  }
  return Object.keys(grupos)
    .sort((a,b) => Number(b)-Number(a)) // Y invertido no PDF
    .map(y => grupos[y].sort((a,b)=>a.x-b.x).map(i=>i.str).join(' ').trim())
    .filter(l => l);
}

// ── PARSER SINAPI PDF ──────────────────────────────────────────────
// Formato linha: CODIGO DESCRICAO UND PRECO_ND [%AS] PRECO_D [%AS]
function parsearSINAPI_PDF(paginas) {
  const itens = [];
  let grupoAtual = 'Geral';
  const reGrupo = /^Grupo\s+(.+?)(?:\s*\(|$)/;
  const reComp  = /^(\d{4,6})\s+(.+?)\s+(M2|M3|UN|KG|VB|CJ|HA|PA|KM|GL|PT|M\b|H\b|T\b|L\b)\s+([\d\.]+,\d+|-)\s*(\d+%|-)?\s*([\d\.]+,\d+|-)?\s*(\d+%|-)?/i;

  for(const pg of paginas) {
    for(const linha of pdfLinhas(pg)) {
      const txt = linha.trim();
      const mG = txt.match(reGrupo);
      if(mG) { grupoAtual = mG[1].trim(); continue; }
      const m = txt.match(reComp);
      if(m) {
        const nd = pNum(m[4]), d = pNum(m[6]||'0');
        if(nd > 0 || d > 0) itens.push({
          codigo:    m[1].trim(),
          descricao: m[2].trim(),
          unidade:   m[3].trim().toUpperCase(),
          preco:     nd, precoD: d,
          grupo:     grupoAtual, fonte: 'SINAPI'
        });
      }
    }
  }
  return itens;
}

// ── PARSER SEOP/SEDOP PDF ─────────────────────────────────────────
// Hierarquia: 001.01.01 → Composição CODIGO desc UND TOTAL
//                       → Composição Auxiliar CODIGO desc UND QTD VUNIT TOTAL
//                       → Insumo CODIGO desc TIPO UND QTD VUNIT TOTAL
function parsearSEOP_PDF(paginas) {
  const resultado = [];
  let comp = null, descPendente = null;
  const SKIP = ['GOVERNO DO ESTADO','SECRETARIA DE ESTADO','DIRETORIA TÉCNICA',
                'COORDENADORIA','SEM DESONERAÇÃO','COM DESONERAÇÃO','COMPOSIÇÕES PRINCIPAIS'];

  for(const pg of paginas) {
    for(const linha of pdfLinhas(pg)) {
      const txt = linha.trim();
      if(!txt) continue;
      if(SKIP.some(s => txt.includes(s))) continue;
      if(/^\d+\/\d+$/.test(txt)) continue; // rodapé "1/181"
      // Ignorar linha "COMPOSIÇÃO DE CUSTO UNITÁRIO - MÊS ANO"
      if(/^COMPOSIÇÃO DE CUSTO UNITÁRIO/.test(txt)) continue;

      // === NOVA SEÇÃO: "001.01.01 Código Descrição ..." ===
      const mSec = txt.match(/^(\d{3}\.\d{2}\.\d{2})\b/);
      if(mSec) {
        if(comp && comp.preco > 0) resultado.push(comp);
        const secId = mSec[1];
        comp = {
          id_seop: secId, codigo:'', descricao:'', unidade:'',
          preco:0, precoD:0, insumos:[], fonte:'SEOP-PA',
          grupo: secId.substring(0,6)
        };
        descPendente = null;
        continue;
      }
      if(!comp) continue;

      const p = txt.split(/\s+/);

      // === COMPOSIÇÃO PRINCIPAL: "Composição CODIGO ...desc... UND TOTAL" ===
      if(p[0]==='Composição' && p[1]!=='Auxiliar') {
        const codigo = p[1] || '';
        const rest   = p.slice(2);
        // Último token = total (número), penúltimo = unidade
        let total=0, und='', descParts=rest;
        for(let i=rest.length-1;i>=0;i--) {
          const v = pNum(rest[i]);
          if(v>0 || rest[i]==='0,00') {
            total = v; und = rest[i-1]||''; descParts = rest.slice(0,Math.max(0,i-1)); break;
          }
        }
        let desc = descParts.join(' ');
        if(descPendente) { desc = descPendente+' '+desc; descPendente=null; }
        comp.codigo    = codigo;
        comp.descricao = desc.trim();
        comp.unidade   = und;
        comp.preco     = total;
        continue;
      }

      // === COMPOSIÇÃO AUXILIAR: "Composição Auxiliar CODIGO desc UND QTD VUNIT TOTAL" ===
      if(p[0]==='Composição' && p[1]==='Auxiliar') {
        const codigo = p[2]||'';
        const rest   = p.slice(3);
        const {desc,und,nums} = extrairDUNT(rest);
        if(nums.length>=2) comp.insumos.push({
          codigo, descricao:desc, tipo:'MO',
          unidade:und, quantidade:nums[0],
          valorUnit:nums[1], total:nums[2]||0
        });
        continue;
      }

      // === INSUMO: "Insumo CODIGO desc TIPO UND QTD VUNIT TOTAL" ===
      if(p[0]==='Insumo') {
        const codigo = p[1]||'';
        const rest   = p.slice(2);
        // Remover tipo (Material/Equipamento/Taxas/Serviço) antes de UND
        const TIPOS = ['Material','Equipamento','Taxas','Serviço','Mão'];
        let tipoIdx = -1;
        for(let i=rest.length-4;i>=0;i--) {
          if(TIPOS.includes(rest[i])) { tipoIdx=i; break; }
        }
        let tipo='Material', restSemTipo=rest;
        if(tipoIdx>=0) { tipo=rest[tipoIdx]; restSemTipo=rest.filter((_,i)=>i!==tipoIdx); }
        const {desc,und,nums} = extrairDUNT(restSemTipo);
        if(nums.length>=2) comp.insumos.push({
          codigo, descricao:desc, tipo,
          unidade:und, quantidade:nums[0],
          valorUnit:nums[1], total:nums[2]||0
        });
        continue;
      }

      // === LINHA SOLTA = primeira parte da descrição quebrada ===
      if(!comp.codigo && !txt.startsWith('Composição') && !txt.startsWith('Insumo')) {
        descPendente = txt;
      }
    }
  }
  if(comp && comp.preco>0) resultado.push(comp);
  return resultado;
}

// Extrai descrição, unidade e array de números dos tokens do fim de uma linha
function extrairDUNT(tokens) {
  const nums = [];
  let end = tokens.length;
  for(let i=tokens.length-1;i>=0;i--) {
    const v = pNum(tokens[i]);
    if(!isNaN(v) && (tokens[i].includes(',') || tokens[i].includes('.'))) {
      nums.unshift(v); end=i;
    } else if(nums.length>0) break;
  }
  const und   = tokens[Math.max(0,end-1)]||'';
  const desc  = tokens.slice(0,Math.max(0,end-1)).join(' ');
  return {desc, und, nums};
}

// ── PARSER GENÉRICO PDF ──────────────────────────────────────────
function parsearGenericoPDF(paginas, fonte) {
  const itens = [];
  const re = /^(\w[\w\.\-\/]+)\s+(.{8,}?)\s+(M2|M3|UN|KG|VB|un|m2|m3|kg|m²)\s+([\d\.,]+)/i;
  for(const pg of paginas)
    for(const linha of pdfLinhas(pg)) {
      const m = linha.trim().match(re);
      if(m) itens.push({codigo:m[1].trim(),descricao:m[2].trim(),
        unidade:m[3].toUpperCase(),preco:pNum(m[4]),precoD:0,
        grupo:'Geral',fonte});
    }
  return itens;
}

// ── PROCESSADOR EXCEL/CSV ────────────────────────────────────────
async function processarTabelaExcel(file, id, nome) {
  if(typeof XLSX === 'undefined') await carregarScript('https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js');
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const wb   = XLSX.read(e.target.result, {type:'binary'});
      const ws   = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSX.utils.sheet_to_json(ws, {header:1, defval:''});
      const cab  = encontrarCabecalho(rows);
      const hdr  = cab ? cab.headerRow.map(c=>(c||'').toString().toLowerCase()) : [];
      const isSinapi = hdr.some(c=>c.includes('sem desoner')||c.includes('com desoner'));
      const itens = isSinapi ? parsearSINAPI_Excel(rows,cab) : parsearExcelGenerico(rows,cab);
      if(!itens.length){mostrarNotificacao('Nenhum item encontrado.','error');return;}
      finalizarImportacao(itens, id, nome, 'Excel', '');
    } catch(err){mostrarNotificacao('Erro ao ler Excel: '+err.message,'error');}
  };
  reader.readAsArrayBuffer(file);
}

function parsearSINAPI_Excel(rows, cab) {
  const itens = [];
  const hdr = cab ? cab.headerRow.map(c=>(c||'').toString().toLowerCase()) : [];
  const hi  = cab ? cab.headerIndex : 0;
  let cCod=-1,cDesc=-1,cUnd=-1,cND=-1,cD=-1;
  hdr.forEach((h,i)=>{
    if(h.includes('cód')||h.includes('codigo')) cCod=i;
    if(h.includes('descri')) cDesc=i;
    if(h.includes('unid')) cUnd=i;
    if(h.includes('sem desoner')) cND=i;
    if(h.includes('com desoner')) cD=i;
  });
  if(cDesc<0) cDesc=1; if(cND<0) cND=3;
  for(let i=hi+1;i<rows.length;i++){
    const r=rows[i]; if(!r||!r.length) continue;
    const desc=(cDesc>=0?(r[cDesc]||'').toString().trim():'');
    if(!desc||desc.length<3) continue;
    itens.push({
      codigo:(cCod>=0?(r[cCod]||'').toString().trim():''),
      descricao:desc, unidade:(cUnd>=0?(r[cUnd]||'').toString().trim():'un'),
      preco:pNum((r[cND]||'').toString()), precoD:pNum((r[cD>=0?cD:cND]||'').toString()),
      grupo:'Geral', fonte:'SINAPI'
    });
  }
  return itens;
}

function parsearExcelGenerico(rows, cab) {
  const itens = [];
  const cols = cab ? detectarColunas(cab.headerRow) : {codigo:0,descricao:1,unidade:2,preco:3};
  const hi   = cab ? cab.headerIndex : 0;
  for(let i=hi+1;i<rows.length;i++){
    const r=rows[i]; if(!r||!r.length) continue;
    const desc=(cols.descricao>=0?(r[cols.descricao]||'').toString().trim():'');
    if(!desc||desc.length<3) continue;
    itens.push({
      codigo:(cols.codigo>=0?(r[cols.codigo]||'').toString().trim():''),
      descricao:desc, unidade:(cols.unidade>=0?(r[cols.unidade]||'').toString().trim():'un'),
      preco:pNum((cols.preco>=0?r[cols.preco]||'':'').toString()),
      precoD:0, grupo:'Geral', fonte:'Importado'
    });
  }
  return itens;
}

// ── UTILITÁRIOS ───────────────────────────────────────────────────
function pNum(s) {
  if(!s || s==='-') return 0;
  const t = s.toString().replace(/R\$\s*/g,'').replace(/\s/g,'');
  if(t.includes(',')) return parseFloat(t.replace(/\./g,'').replace(',','.')) || 0;
  return parseFloat(t) || 0;
}

// Manter parsePreco como alias
function parsePreco(s){ return pNum(s); }

function finalizarImportacao(itens, id, nome, formato, mesRef) {
  if(!mesRef) mesRef = new Date().toLocaleDateString('pt-BR',{month:'2-digit',year:'numeric'});
  salvarTabelaExtra(id, nome, itens, mesRef);
  // Atualizar o orçamento com a tabela e mês recém importados
  orcDados().refTabela = id;
  orcDados().refMes    = mesRef;
  if(id.startsWith('SINAPI')) {
    orcDados().tabelaImportada = itens;
    setSinapiMesRef(mesRef);
    setSinapiUltimaAt(new Date().toISOString());
  }
  // Usar setTabelaAtiva com o mesRef para sincronizar tudo
  setTabelaAtiva(id, mesRef);
  mostrarNotificacao(`✅ ${nome} ${mesRef}: ${itens.length} composições importadas! (${formato})`, 'success');
  _tabPrecosAba = 'locais';
  mudarSubOrc('tabPrecos');
}



