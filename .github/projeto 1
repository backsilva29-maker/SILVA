function calcularBDITotal(bdi) {
  if(!bdi) return 0;
  const ac  = (bdi.ac||0)/100;
  const s   = (bdi.s||0)/100;
  const r   = (bdi.r||0)/100;
  const g   = (bdi.g||0)/100;
  const df  = (bdi.df||0)/100;
  const risk= (bdi.risk||0)/100;
  const l   = (bdi.l||0)/100;
  const num = (1+ac)*(1+s+r+g)*(1+df+risk);
  const den = 1-l;
  if(den<=0) return 0;
  return ((num/den)-1)*100;
}

