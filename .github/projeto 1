function handleArquivos(files){
  _arquivosBuffer=[];
  const prev=document.getElementById('arqPreviewArea');
  const meta=document.getElementById('arqMetaArea');
  if(!files.length) return;
  const autoCateg = autoCategoriaArquivo(files[0].name);
  prev.innerHTML=`<div style="font-size:11px;color:var(--text2);margin-bottom:8px">${files.length} arquivo(s) selecionado(s):</div><div style="display:flex;flex-direction:column;gap:6px" id="arqLista"></div>`;
  const lista=prev.querySelector('#arqLista');
  let loaded=0;
  Array.from(files).forEach(file=>{
    const reader=new FileReader();
    reader.onload=e=>{
      const categ=autoCategoriaArquivo(file.name);
      _arquivosBuffer.push({nome:file.name,data64:e.target.result,tamanho:file.size,tipo:file.type,categoriaAuto:categ});
      const item=document.createElement('div');
      item.style.cssText='display:flex;align-items:center;gap:10px;background:var(--surface2);border-radius:8px;padding:8px 12px;font-size:12px';
      item.innerHTML=`<span style="font-size:18px">${iconeArquivo(file.name)}</span>
        <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${file.name}</span>
        <span style="font-size:10px;background:rgba(232,160,32,.15);color:var(--accent);border-radius:10px;padding:2px 8px;white-space:nowrap">${categ}</span>
        <span style="color:var(--text3);font-size:10px;white-space:nowrap">${fmtTamanho(file.size)}</span>`;
      lista.appendChild(item);
      if(++loaded===files.length){
        meta.style.display='block';
        const sel=document.getElementById('arqCategoria');
        if(sel){ const opts=Array.from(sel.options); const match=opts.find(o=>o.value===autoCateg); if(match) sel.value=autoCateg; }
      }
    };
    reader.readAsDataURL(file);
  });
}
