// Garante estrutura bibComp nos dados
function bibCompDados() {
  if(!dados.bibComp) dados.bibComp = { composicoes: [] };
  return dados.bibComp;
}

// Busca insumo em tabelaImportada ou Supabase (retorna Promise)
async function bibCompBuscarPreco(codigo) {
  const orc = orcDados();
  // 1) tabela local
  if(orc.tabelaImportada && orc.tabelaImportada.length>0) {
    const enc = orc.tabelaImportada.find(t=>(t.codigo||'').toString().trim()===codigo.trim());
    if(enc) return { preco: parseFloat(enc.preco)||0, fonte: orc.refTabela||'Local' };
  }
  // 2) Supabase tabela_precos
  try {
    const r = await fetch(`${SUPABASE_URL}/rest/v1/tabela_precos?codigo=eq.${encodeURIComponent(codigo.trim())}&limit=1`,{
      headers:{'apikey':SUPABASE_KEY,'Authorization':'Bearer '+SUPABASE_KEY}
    });
    const rows = await r.json();
    if(Array.isArray(rows)&&rows.length>0) return { preco: parseFloat(rows[0].preco_unit)||0, fonte: rows[0].fonte||'Supabase' };
  } catch(e){}
  return null;
}

